{
	"name": "df_APCCrosswalk_step3",
	"properties": {
		"folder": {
			"name": "apc/silver to gold/APCCrosswalk"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_APC_Crosswalk_APC_Map",
						"type": "DatasetReference"
					},
					"name": "sourceCrosswalkAPCMap"
				},
				{
					"dataset": {
						"referenceName": "ds_APCMaster_APCTitles",
						"type": "DatasetReference"
					},
					"name": "sourceAPCTitles"
				},
				{
					"dataset": {
						"referenceName": "ds_APCImport_Tidy",
						"type": "DatasetReference"
					},
					"name": "sourceAPCTidy"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_APC_Crosswalk_APCCrosswalk",
						"type": "DatasetReference"
					},
					"name": "sinkAPCCrosswalk"
				},
				{
					"dataset": {
						"referenceName": "ds_APCMaster_APCTitles",
						"type": "DatasetReference"
					},
					"name": "sinkAPCTitles"
				},
				{
					"dataset": {
						"referenceName": "ds_APCImport_Tidy",
						"type": "DatasetReference"
					},
					"name": "sinkAPCTidy"
				}
			],
			"transformations": [
				{
					"name": "aggregate1"
				},
				{
					"name": "join1"
				},
				{
					"name": "join2"
				},
				{
					"name": "select1"
				},
				{
					"name": "filter1"
				},
				{
					"name": "selectAPCCrosswalk"
				},
				{
					"name": "join3"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select2"
				},
				{
					"name": "join4"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "select3"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Title_ID as integer,",
				"          APC_ID as short,",
				"          Match_using as string,",
				"          Priority as short",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceCrosswalkAPCMap",
				"source(output(",
				"          APC_ID as string,",
				"          ISSN_L as string,",
				"          Title_ID as string,",
				"          Source_title as string,",
				"          Title as string,",
				"          Publisher as string,",
				"          Publisher_Short as string,",
				"          Publisher_Short_OA as string,",
				"          Year as string,",
				"          Model as string,",
				"          APC as string,",
				"          Source_title_history as string,",
				"          Title_history as string,",
				"          Publisher_history as string,",
				"          Publisher_history_OA as string,",
				"          Year_history as string,",
				"          ID_history as string,",
				"          wUID as string,",
				"          Contiguous as string,",
				"          Updates as string,",
				"          Child_records as string,",
				"          Change_publisher as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceAPCTitles",
				"source(output(",
				"          APC_ID as short,",
				"          Title_ID as string,",
				"          ISSN_L as string,",
				"          Publisher_Short as string,",
				"          Publisher_Short_OA as string,",
				"          Publisher_OA_type as string,",
				"          Unique_title as string,",
				"          wUID as short,",
				"          Import1ID as string,",
				"          Import2ID as string,",
				"          Publisher as string,",
				"          ISSN1 as string,",
				"          ISSN2 as string,",
				"          Title as string,",
				"          Source_title as string,",
				"          Source as string,",
				"          Model as string,",
				"          Model_Notes as string,",
				"          APC as string,",
				"          Currency as string,",
				"          Year as short,",
				"          DAO as short,",
				"          LicenseType as string,",
				"          PublisherID as string,",
				"          JoiningID as string,",
				"          Imprint as string,",
				"          Society as string,",
				"          TJ as string,",
				"          Audit as string,",
				"          Import1_Old_Table as string,",
				"          Import1_Old_wUID as string,",
				"          Import1_Old_Year as string,",
				"          Present_via as string,",
				"          Import2_Old_Table as string,",
				"          Import2_Old_wUID as string,",
				"          Import2_Old_Year as string,",
				"          ISSN_X as string,",
				"          ISSNs_in_order as string,",
				"          IY as string,",
				"          IYP as string,",
				"          Publication_Data_Year as short,",
				"          Metrics_Data_Year as short,",
				"          Currency_Data_Year as short,",
				"          Inflation_Data_Year as short,",
				"          last_year_APC as string,",
				"          years_zero_APC as boolean,",
				"          last_year_model as string,",
				"          next_year_model as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceAPCTidy",
				"sourceCrosswalkAPCMap aggregate(groupBy(APC_ID),",
				"     Priority = min(Priority)) ~> aggregate1",
				"aggregate1, sourceCrosswalkAPCMap join(aggregate1@APC_ID == sourceCrosswalkAPCMap@APC_ID",
				"     && aggregate1@Priority == sourceCrosswalkAPCMap@Priority,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1, sourceAPCTitles join(toString(sourceCrosswalkAPCMap@APC_ID) == sourceAPCTitles@APC_ID,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join2",
				"join2 select(mapColumn(",
				"          Title_ID = sourceCrosswalkAPCMap@Title_ID,",
				"          APC_ID = sourceCrosswalkAPCMap@APC_ID,",
				"          Match_using,",
				"          Priority = sourceCrosswalkAPCMap@Priority,",
				"          ISSN_L,",
				"          Source_title,",
				"          Title,",
				"          Publisher,",
				"          Publisher_Short,",
				"          Year,",
				"          Model,",
				"          wUID",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 filter(not(isNull(APC_ID)) && not(isNull(Title_ID))) ~> filter1",
				"filter1 select(mapColumn(",
				"          Title_ID,",
				"          APC_ID,",
				"          Match_using,",
				"          Priority,",
				"          ISSN_L,",
				"          Source_title,",
				"          Title,",
				"          Publisher,",
				"          Publisher_Short,",
				"          Year,",
				"          Model,",
				"          wUID",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectAPCCrosswalk",
				"sourceAPCTitles, selectAPCCrosswalk join(sourceAPCTitles@APC_ID == toString(selectAPCCrosswalk@APC_ID),",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join3",
				"join3 derive(Title_ID = selectAPCCrosswalk@Title_ID) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          APC_ID = sourceAPCTitles@APC_ID,",
				"          ISSN_L = sourceAPCTitles@ISSN_L,",
				"          Title_ID,",
				"          Source_title = sourceAPCTitles@Source_title,",
				"          Title = sourceAPCTitles@Title,",
				"          Publisher = sourceAPCTitles@Publisher,",
				"          Publisher_Short = sourceAPCTitles@Publisher_Short,",
				"          Publisher_Short_OA,",
				"          Year = sourceAPCTitles@Year,",
				"          Model = sourceAPCTitles@Model,",
				"          APC,",
				"          Source_title_history,",
				"          Title_history,",
				"          Publisher_history,",
				"          Publisher_history_OA,",
				"          Year_history,",
				"          ID_history,",
				"          wUID = sourceAPCTitles@wUID,",
				"          Contiguous,",
				"          Updates,",
				"          Child_records,",
				"          Change_publisher",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"sourceAPCTidy, selectAPCCrosswalk join(sourceAPCTidy@APC_ID == selectAPCCrosswalk@APC_ID,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join4",
				"join4 derive(Title_ID = selectAPCCrosswalk@Title_ID) ~> derivedColumn2",
				"derivedColumn2 select(mapColumn(",
				"          APC_ID = sourceAPCTidy@APC_ID,",
				"          Title_ID,",
				"          ISSN_L = sourceAPCTidy@ISSN_L,",
				"          Publisher_Short = sourceAPCTidy@Publisher_Short,",
				"          Publisher_Short_OA,",
				"          Publisher_OA_type,",
				"          Unique_title,",
				"          wUID = sourceAPCTidy@wUID,",
				"          Import1ID,",
				"          Import2ID,",
				"          Publisher = sourceAPCTidy@Publisher,",
				"          ISSN1,",
				"          ISSN2,",
				"          Title = sourceAPCTidy@Title,",
				"          Source_title = sourceAPCTidy@Source_title,",
				"          Source,",
				"          Model = sourceAPCTidy@Model,",
				"          Model_Notes,",
				"          APC,",
				"          Currency,",
				"          Year = sourceAPCTidy@Year,",
				"          DAO,",
				"          LicenseType,",
				"          PublisherID,",
				"          JoiningID,",
				"          Imprint,",
				"          Society,",
				"          TJ,",
				"          Audit,",
				"          Import1_Old_Table,",
				"          Import1_Old_wUID,",
				"          Import1_Old_Year,",
				"          Present_via,",
				"          Import2_Old_Table,",
				"          Import2_Old_wUID,",
				"          Import2_Old_Year,",
				"          ISSN_X,",
				"          ISSNs_in_order,",
				"          IY,",
				"          IYP,",
				"          Publication_Data_Year,",
				"          Metrics_Data_Year,",
				"          Currency_Data_Year,",
				"          Inflation_Data_Year,",
				"          last_year_APC,",
				"          years_zero_APC,",
				"          last_year_model,",
				"          next_year_model",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"selectAPCCrosswalk sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkAPCCrosswalk",
				"select2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          APC_ID as string,",
				"          ISSN_L as string,",
				"          Title_ID as string,",
				"          Source_title as string,",
				"          Title as string,",
				"          Publisher as string,",
				"          Publisher_Short as string,",
				"          Publisher_Short_OA as string,",
				"          Year as string,",
				"          Model as string,",
				"          APC as string,",
				"          Source_title_history as string,",
				"          Title_history as string,",
				"          Publisher_history as string,",
				"          Publisher_history_OA as string,",
				"          Year_history as string,",
				"          ID_history as string,",
				"          wUID as string,",
				"          Contiguous as string,",
				"          Updates as string,",
				"          Child_records as string,",
				"          Change_publisher as string",
				"     ),",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkAPCTitles",
				"select3 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkAPCTidy"
			]
		}
	}
}