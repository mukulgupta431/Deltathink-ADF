{
	"name": "14_df_ACS_processing_copy1",
	"properties": {
		"folder": {
			"name": "apc/abkup"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_ACS_bronze_all_journals",
						"type": "DatasetReference"
					},
					"name": "sourceAllJournal"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_ACS_silver_all_journals",
						"type": "DatasetReference"
					},
					"name": "sinkList1AllJournal"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Coden as string,",
				"          Publication as string,",
				"          {First Year of Publication*} as string,",
				"          {Open Access Options? acsopenscience.org} as string,",
				"          {Access Method for non-OA Content} as string,",
				"          {First Year Available with a Front-File Subscription**} as string,",
				"          URL as string,",
				"          {Issues Per Year Online} as string,",
				"          {Print ISSN} as string,",
				"          {Print Svc Code} as string,",
				"          {Web ISSN} as string,",
				"          {Included in All Publications Package} as string,",
				"          {Included in ACS Core Plus Package} as string,",
				"          {Optional in Science Essentials Package} as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceAllJournal",
				"sourceAllJournal derive(Publisher = 'ACS',",
				"          ISSN1 = {Web ISSN},",
				"          ISSN2 = iif(like({Print ISSN},'%Web Only%'),'',trim({Print ISSN})),",
				"          Title = :Title_v,",
				"          Source = 'Publisher Website',",
				"          Model = :Model_v,",
				"          {Model Notes} = toString(null()),",
				"          APC = iif(\r",
				"    :Model_v == 'Hybrid',4500,\r",
				"     iif(\r",
				"        :Title_v =='ACS Central Science',0,\r",
				"            iif(\r",
				"                :Title_v == 'ACS Omega',1935,\r",
				"                3500)\r",
				"        )\r",
				"    )           \r",
				"/* APC is 4500 for all Hybrid Journals;\r",
				"    for all open access journals except 'ACS Omega' and 'ACS Central Science' 3500 */,",
				"          currency = 'USD',",
				"          year = :year_v,",
				"          PublisherID = Coden,",
				"          JoiningID = Coden,",
				"          Imprint = toString(null()),",
				"          Society = toString(null()),",
				"          year_v := '2024',",
				"          Model_v := case({Access Method for non-OA Content}==\"Open Access Only\",\"Fully OA\",'Hybrid'),",
				"          Title_v := regexReplace(Publication, '\\\\(.*?\\\\)', '')\r",
				"/* to eliminate content within paranthesis. ex-replace \"ACS ES&T Air (New in 2024)\" as \"ACS ES&T Air\" */) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          Publisher,",
				"          ISSN1,",
				"          ISSN2,",
				"          Title,",
				"          Source,",
				"          Model,",
				"          {Model Notes},",
				"          APC,",
				"          Currency = currency,",
				"          Year = year,",
				"          PublisherID,",
				"          JoiningID,",
				"          Imprint,",
				"          Society",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkList1AllJournal"
			]
		}
	}
}