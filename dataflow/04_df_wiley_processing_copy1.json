{
	"name": "04_df_wiley_processing_copy1",
	"properties": {
		"folder": {
			"name": "apc/abkup"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_wiley_bronze_all_journals",
						"type": "DatasetReference"
					},
					"name": "sourceAll"
				},
				{
					"dataset": {
						"referenceName": "ds_wiley_bronze_hybrid",
						"type": "DatasetReference"
					},
					"name": "sourceHybrid"
				},
				{
					"dataset": {
						"referenceName": "ds_wiley_bronze_freeoa_journals",
						"type": "DatasetReference"
					},
					"name": "sourceFreeOA"
				},
				{
					"dataset": {
						"referenceName": "ds_wiley_bronze_oa_journals",
						"type": "DatasetReference"
					},
					"name": "sourceOA"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_wiley_silver_all_journals",
						"type": "DatasetReference"
					},
					"name": "sinkAllJournalList1"
				},
				{
					"dataset": {
						"referenceName": "ds_wiley_silver_oa_journals",
						"type": "DatasetReference"
					},
					"name": "sinklist2"
				},
				{
					"dataset": {
						"referenceName": "ds_Hindawi_silver_all_journals",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "lookupHybrid"
				},
				{
					"name": "select1"
				},
				{
					"name": "select2"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "select3"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "derivedColumn5"
				},
				{
					"name": "lookupOA"
				},
				{
					"name": "select4"
				},
				{
					"name": "derivedColumn6"
				},
				{
					"name": "derivedColumn7"
				},
				{
					"name": "select5"
				},
				{
					"name": "derivedColumn8"
				},
				{
					"name": "filter1"
				},
				{
					"name": "filter2"
				},
				{
					"name": "select6"
				},
				{
					"name": "derivedColumn9"
				}
			],
			"scriptLines": [
				"source(output(",
				"          {Journal Group code (numeric)} as string,",
				"          {Journal Group code (alpha)} as string,",
				"          {MJ code} as string,",
				"          {Print ISSN} as string,",
				"          {Print Journal Code} as string,",
				"          {Digital ISSN} as string,",
				"          {Digital Journal Code} as string,",
				"          Title as string,",
				"          {Print Material Number} as string,",
				"          {Print Status} as string,",
				"          {Digital Material Number} as string,",
				"          {_c11} as string,",
				"          {Digital Status} as string,",
				"          {MultiMedia SAP Material} as string,",
				"          {FTE Price Model} as string,",
				"          DOI as string,",
				"          URL as string,",
				"          {General Subject Category} as string,",
				"          {Primary Subject Area} as string,",
				"          {Media Type} as string,",
				"          {External notes PRICING} as string,",
				"          {Hybrid Open Access } as boolean,",
				"          {Available For POD} as boolean,",
				"          {Included In Database} as boolean,",
				"          {Full Collection} as string,",
				"          {STM Collection} as string,",
				"          {SSH Collection} as string,",
				"          {M&N Collection} as string,",
				"          {Not in any Standard Collections} as string,",
				"          {R4L Collection} as string,",
				"          {Current Year Volume} as string,",
				"          {Current Year Issue} as short,",
				"          {Frontfile Start Year} as short,",
				"          {Frontfile Start Volume} as string,",
				"          {Year of First Backfile Volume} as short,",
				"          {First Backfile Volume Available} as string,",
				"          {First Backfile Isssue Available} as string,",
				"          {Year of Last Backfile Volume} as short,",
				"          {Last Backfile Volume Available} as short,",
				"          {Last Backfile Issue Available} as string,",
				"          {Renewal Subscription Type} as string,",
				"          {Journal Owned by} as string,",
				"          {Impact Factor 2023} as double",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceAll",
				"source(output(",
				"          {Journal Title} as string,",
				"          {Online ISSN} as string,",
				"          {Subject Area} as string,",
				"          {License types offered} as string,",
				"          USD as short,",
				"          GBP as short,",
				"          EUR as short",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceHybrid",
				"source(output(",
				"          {Journal Group code} as string,",
				"          {Print ISSN} as string,",
				"          {Print Journal Code} as string,",
				"          {Digital ISSN} as string,",
				"          {Digital Journal Code} as string,",
				"          Title as string,",
				"          {Print Material Number} as string,",
				"          {Print Status} as string,",
				"          {Digital Material Number} as string,",
				"          {Digital Status} as string,",
				"          {MultiMedia SAP Material} as string,",
				"          {FTE Price Model} as boolean,",
				"          DOI as string,",
				"          URL as string,",
				"          {Renewal Subscription Type} as string,",
				"          {Journal Owned by} as string,",
				"          {General Subject Category} as string,",
				"          {Primary Subject Area} as string,",
				"          {Impact Factor 2022} as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceFreeOA",
				"source(output(",
				"          {Journal Name} as string,",
				"          {Subject Area} as string,",
				"          {Online ISSN} as string,",
				"          {License Types Offered} as string,",
				"          USD as short,",
				"          GBP as short,",
				"          EUR as short",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceOA",
				"lookupHybrid derive(Publisher = 'Wiley',",
				"          ISSN1 = iif(length({Digital ISSN})>8, trim({Digital ISSN}), ''),",
				"          ISSN2 = iif(length({Print ISSN})>8,iif({Print ISSN}!='2405-4690',trim({Print ISSN}),''),''),",
				"          Title = trim(select2@Title),",
				"          Source = 'Publisher Price List',",
				"          Model = iif(",
				"    {Digital ISSN} == JoiningID || left(toString({Hybrid Open Access }),1)=='Y' || isNull({FTE Price Model}),",
				"    'Hybrid',",
				"    'None' ),",
				"          {Model Notes} = toString(null()),",
				"          APC = APC,",
				"          Currency = 'USD',",
				"          {License Types} = toString(null()),",
				"          Year = '2025',",
				"          PublisherID = toString(null()),",
				"          JoiningID = {Digital ISSN},",
				"          Imprint = iif(left({Journal Owned by},5)=='Wiley' || left({Journal Owned by},6)=='Blackw',{Journal Owned by},''),",
				"          Society = iif (",
				"    ({Journal Owned by} =='Wiley' || {Journal Owned by} == 'Wiley-VCH' || ",
				"    {Journal Owned by} == 'Blackwell' || {Journal Owned by} =='John Wiley & Sons Australia, Ltd' ||",
				"    {Journal Owned by} == 'John Wiley & Sons Ltd' ||{Journal Owned by} =='John Wiley & Sons'),",
				"    '',",
				"    trim({Journal Owned by}))",
				"",
				" /* Tried the above with in clause. but didnt work for ('Wiley', 'Wiley-VCH', 'Wiley VCH', 'Blackwell','John Wiley & Sons Australia, Ltd', 'John Wiley & Sons Ltd', 'John Wiley & Sons') */) ~> derivedColumn1",
				"select2, select3 lookup({Digital ISSN} == ISSN1,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookupHybrid",
				"derivedColumn3 select(mapColumn(",
				"          Publisher,",
				"          ISSN1,",
				"          ISSN2,",
				"          Title,",
				"          Source,",
				"          Model,",
				"          {Model Notes},",
				"          APC,",
				"          Currency,",
				"          {License Types},",
				"          Year,",
				"          PublisherID,",
				"          JoiningID,",
				"          Imprint,",
				"          Society",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"sourceAll select(mapColumn(",
				"          {Print ISSN},",
				"          {Digital ISSN},",
				"          Title,",
				"          {FTE Price Model},",
				"          {Journal Owned by},",
				"          {Hybrid Open Access },",
				"          {Renewal Subscription Type}",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"sourceHybrid derive(Publisher = 'Wiley',",
				"          ISSN1 = :issn_V,",
				"          ISSN2 = toString(null()),",
				"          Title = trim({Journal Title}),",
				"          Source = 'Publisher Price List',",
				"          Model = 'Hybrid',",
				"          {Model Notes} = {License types offered},",
				"          APC = replace(replace(toString(USD),'US$',''),'see website','0'),",
				"          Currency = 'USD',",
				"          {License Types} = toString(null()),",
				"          Year = '2025',",
				"          PublisherID = toString(null()),",
				"          JoiningID = :issn_V,",
				"          Imprint = toString(null()),",
				"          Society = toString(null()),",
				"          issn_V := concat(concat(left({Online ISSN},4),'-'),right({Online ISSN},4))) ~> derivedColumn2",
				"derivedColumn2 select(mapColumn(",
				"          Publisher,",
				"          ISSN1,",
				"          ISSN2,",
				"          Title,",
				"          Source,",
				"          Model,",
				"          {Model Notes},",
				"          APC,",
				"          Currency,",
				"          Year,",
				"          PublisherID,",
				"          JoiningID,",
				"          Imprint,",
				"          Society",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"derivedColumn1 derive({Model Notes} = concat(",
				"    iif({Renewal Subscription Type} == \"Free to read\", {Renewal Subscription Type}, \"\"),",
				"    iif({Renewal Subscription Type} == \"Free to read\" && (Model == \"Hybrid\" && left(toString({Hybrid Open Access }),1) == \"Y\"), \"; \", \"\"),",
				"    iif(Model == \"Hybrid\" && left(toString({Hybrid Open Access }),1) == \"Y\", toString({Hybrid Open Access }), \"\")",
				")",
				"/* validate the above for ; used for concatenation...check how it works by ingnoring null while concatenating  */) ~> derivedColumn3",
				"sourceFreeOA derive(Publisher = 'Wiley',",
				"          ISSN1 = :issn1_V,",
				"          ISSN2 = concat(concat(left({Print ISSN},4),'-'),right({Print ISSN},4)),",
				"          Title = trim({Title}),",
				"          Source = 'Publisher Price List',",
				"          {License Types} = toString(null()),",
				"          Year = '2025',",
				"          PublisherID = :issn1_V,",
				"          JoiningID = :issn1_V,",
				"          Imprint = toString(null()),",
				"          Society = toString(null()),",
				"          issn1_V := concat(concat(left({Digital ISSN},4),'-'),right({Digital ISSN},4))) ~> derivedColumn4",
				"lookupOA derive(Model = 'Fully OA'",
				"",
				"/* iif((not(isNull(derivedColumn6@JoiningID)) || isNull(derivedColumn4@JoiningID)),'Fully OA','Hybrid')",
				" Formula used in excel is =IF(OR(NOT(ISNA([@[OpenAccess]])),ISNA([@[Hybrid]])),\"Fully OA\",\"Hybrid\") ",
				"   Valid entry in OA OR Not in Hybrid then Fully OA, else Hybrid */,",
				"          APC = replace(replace(toString(USD),'US$',''),'see website','0'),",
				"          {Model Notes} = left(iif(",
				"        isNull(derivedColumn6@JoiningID),",
				"        concat(\"Not in OA Price List - \", {Renewal Subscription Type}),",
				"        concat({Renewal Subscription Type}, \" - \")",
				"    ),",
				"    512)",
				"    /* consider only 512 characters in the resultant string */) ~> derivedColumn5",
				"derivedColumn4, derivedColumn7 lookup(derivedColumn4@JoiningID == derivedColumn6@JoiningID,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookupOA",
				"filter2 select(mapColumn(",
				"          Publisher = derivedColumn4@Publisher,",
				"          ISSN1 = derivedColumn4@ISSN1,",
				"          ISSN2 = derivedColumn4@ISSN2,",
				"          Title = derivedColumn4@Title,",
				"          Source = derivedColumn4@Source,",
				"          Model,",
				"          {Model Notes},",
				"          APC,",
				"          Currency,",
				"          {License Types} = derivedColumn4@{License Types},",
				"          Year = derivedColumn4@Year,",
				"          PublisherID = derivedColumn4@PublisherID,",
				"          JoiningID = derivedColumn4@JoiningID,",
				"          Imprint = derivedColumn4@Imprint,",
				"          Society = derivedColumn4@Society",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select4",
				"sourceOA derive(Publisher = 'Wiley',",
				"          ISSN1 = :issn1_V,",
				"          ISSN2 = toString(null()),",
				"          Title = trim({Journal Name}),",
				"          Source = 'Publisher Price List',",
				"          Model = 'Fully OA',",
				"          APC = replace(replace(replace(toString(USD),'US$',''),'see website','0'),'APCs currently waived',toString(USD)),",
				"          {License Types} = toString(null()),",
				"          Year = '2025',",
				"          PublisherID = toString(null()),",
				"          JoiningID = :issn1_V,",
				"          Imprint = toString(null()),",
				"          Society = toString(null()),",
				"          issn1_V := concat(concat(left({Online ISSN},4),'-'),right({Online ISSN},4))) ~> derivedColumn6",
				"derivedColumn6 derive(Currency = iif(isNull(APC),'','USD'),",
				"          APC = iif(isNull(APC),'0',toString(USD))) ~> derivedColumn7",
				"derivedColumn7 select(mapColumn(",
				"          Publisher,",
				"          ISSN1,",
				"          ISSN2,",
				"          Title,",
				"          Source,",
				"          Model,",
				"          {Model Notes} = APC,",
				"          APC,",
				"          Currency,",
				"          Year,",
				"          PublisherID,",
				"          JoiningID,",
				"          Imprint,",
				"          Society",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select5",
				"derivedColumn5 derive(Currency = iif(isNull(APC),'','USD'),",
				"          APC = iif(isNull(APC),'0',APC)) ~> derivedColumn8",
				"derivedColumn8 filter({Journal Owned by} == 'Hindawi') ~> filter1",
				"derivedColumn8 filter({Journal Owned by} != 'Hindawi') ~> filter2",
				"derivedColumn9 select(mapColumn(",
				"          Publisher,",
				"          ISSN1 = derivedColumn4@ISSN1,",
				"          ISSN2 = derivedColumn4@ISSN2,",
				"          Title = derivedColumn4@Title,",
				"          Source = derivedColumn4@Source,",
				"          Model,",
				"          {Model Notes},",
				"          APC,",
				"          Currency,",
				"          {License Types} = derivedColumn4@{License Types},",
				"          Year = derivedColumn4@Year,",
				"          PublisherID = derivedColumn4@PublisherID,",
				"          JoiningID = derivedColumn4@JoiningID,",
				"          Imprint = derivedColumn4@Imprint,",
				"          Society = derivedColumn4@Society",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select6",
				"filter1 derive(Publisher = 'Hindawi') ~> derivedColumn9",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkAllJournalList1",
				"select4 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinklist2",
				"select6 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          {Journal Name} as string,",
				"          {Subject Area} as string,",
				"          {Online ISSN} as string,",
				"          {License Types Offered} as string,",
				"          USD as string,",
				"          GBP as string,",
				"          EUR as string,",
				"          clean_title as string,",
				"          issnl as string",
				"     ),",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}