{
	"name": "df_Thieme_processing",
	"properties": {
		"folder": {
			"name": "apc/bronze to silver/Misc"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_Thieme_bronze_all",
						"type": "DatasetReference"
					},
					"name": "sourceAllJournal"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ls_Thieme_silver_all_journal",
						"type": "DatasetReference"
					},
					"name": "sinkList1AllJournal"
				}
			],
			"transformations": [
				{
					"name": "PreparingList1"
				},
				{
					"name": "selectRequiredColumns"
				}
			],
			"scriptLines": [
				"source(output(",
				"          {Journal Title} as string,",
				"          DOI as string,",
				"          eISSN as string,",
				"          {Publishing Model} as string,",
				"          {Article types} as string,",
				"          {License Type} as string,",
				"          {APC Price in US Dollars} as string,",
				"          {APC Price in Euros} as string,",
				"          {Discount Type} as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceAllJournal",
				"sourceAllJournal derive(Publisher = 'Thieme',",
				"          ISSN1 = trim(eISSN),",
				"          ISSN2 = toString(null()),",
				"          Title = trim({Journal Title}),",
				"          Source = 'Publisher Price List',",
				"          Model = iif(",
				"    {Publishing Model} == 'Fully OA','Fully OA',",
				"    iif({Publishing Model} == 'Hybrid OA','Hybrid',",
				"    'None')",
				"    ),",
				"          {Model Notes} = toString(null()),",
				"          APC = {APC Price in US Dollars},",
				"          Currency = iif(not(isNull({APC Price in US Dollars})),'USD',''),",
				"          {License Types} = {License Type},",
				"          Year = :year_v,",
				"          PublisherID = toString(null()),",
				"          JoiningID = toString(null()),",
				"          Imprint = toString(null()),",
				"          Society = toString(null()),",
				"          year_v := '2025') ~> PreparingList1",
				"PreparingList1 select(mapColumn(",
				"          Publisher,",
				"          ISSN1,",
				"          ISSN2,",
				"          Title,",
				"          Source,",
				"          Model,",
				"          {Model Notes},",
				"          APC,",
				"          Currency,",
				"          {License Types},",
				"          Year,",
				"          PublisherID,",
				"          JoiningID,",
				"          Imprint,",
				"          Society",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRequiredColumns",
				"selectRequiredColumns sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          PubType as string,",
				"          Title as string,",
				"          OnlineUrl as string,",
				"          OnlineYear as string,",
				"          FirstVolume as string,",
				"          OnlineCode as string",
				"     ),",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkList1AllJournal"
			]
		}
	}
}