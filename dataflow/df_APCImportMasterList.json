{
	"name": "df_APCImportMasterList",
	"properties": {
		"folder": {
			"name": "apc/silver to gold/APCMasterList"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_APCMaster_APCTitles",
						"type": "DatasetReference"
					},
					"name": "sourceAPCTitles"
				},
				{
					"dataset": {
						"referenceName": "ds_APCImport_Tidy",
						"type": "DatasetReference"
					},
					"name": "sourceAPCTidy"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_APCMaster_APCTitles",
						"type": "DatasetReference"
					},
					"name": "sinkAPCTitles"
				}
			],
			"transformations": [
				{
					"name": "filter1"
				},
				{
					"name": "APCMostRecents"
				},
				{
					"name": "JoinMostRecentMetadata"
				},
				{
					"name": "selectTidyRequiredColumns"
				},
				{
					"name": "SplitNewAndExisting"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "UpdateExistingTitlesRecords"
				},
				{
					"name": "select4"
				},
				{
					"name": "aggregate1"
				},
				{
					"name": "select5"
				},
				{
					"name": "select6"
				},
				{
					"name": "select7"
				},
				{
					"name": "union1"
				},
				{
					"name": "join1"
				},
				{
					"name": "join2"
				},
				{
					"name": "select8"
				},
				{
					"name": "surrogateKey2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          APC_ID as short,",
				"          ISSN_L as string,",
				"          Title_ID as integer,",
				"          Source_title as string,",
				"          Title as string,",
				"          Publisher as string,",
				"          Publisher_Short as string,",
				"          Publisher_Short_OA as string,",
				"          Year as short,",
				"          Model as string,",
				"          APC as string,",
				"          Source_title_history as string,",
				"          Title_history as string,",
				"          Publisher_history as string,",
				"          Publisher_history_OA as string,",
				"          Year_history as string,",
				"          ID_history as string,",
				"          wUID as integer,",
				"          Contiguous as boolean,",
				"          Updates as short,",
				"          Child_records as short,",
				"          Change_publisher as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceAPCTitles",
				"source(output(",
				"          APC_ID as short,",
				"          Title_ID as string,",
				"          ISSN_L as string,",
				"          Publisher_Short as string,",
				"          Publisher_Short_OA as string,",
				"          Publisher_OA_type as string,",
				"          Unique_title as string,",
				"          wUID as short,",
				"          Import1ID as string,",
				"          Import2ID as string,",
				"          Publisher as string,",
				"          ISSN1 as string,",
				"          ISSN2 as string,",
				"          Title as string,",
				"          Source_title as string,",
				"          Source as string,",
				"          Model as string,",
				"          Model_Notes as string,",
				"          APC as string,",
				"          Currency as string,",
				"          Year as short,",
				"          DAO as short,",
				"          LicenseType as string,",
				"          PublisherID as string,",
				"          JoiningID as string,",
				"          Imprint as string,",
				"          Society as string,",
				"          TJ as string,",
				"          Audit as string,",
				"          Import1_Old_Table as string,",
				"          Import1_Old_wUID as string,",
				"          Import1_Old_Year as string,",
				"          Present_via as string,",
				"          Import2_Old_Table as string,",
				"          Import2_Old_wUID as string,",
				"          Import2_Old_Year as string,",
				"          ISSN_X as string,",
				"          ISSNs_in_order as string,",
				"          IY as string,",
				"          IYP as string,",
				"          Publication_Data_Year as short,",
				"          Metrics_Data_Year as short,",
				"          Currency_Data_Year as short,",
				"          Inflation_Data_Year as short,",
				"          last_year_APC as string,",
				"          years_zero_APC as boolean,",
				"          last_year_model as string,",
				"          next_year_model as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceAPCTidy",
				"sourceAPCTidy filter(not(isNull(ISSN_L))) ~> filter1",
				"selectTidyRequiredColumns aggregate(groupBy(ISSN_L),",
				"     Year = max(Year)) ~> APCMostRecents",
				"APCMostRecents, selectTidyRequiredColumns join(APCMostRecents@ISSN_L == selectTidyRequiredColumns@ISSN_L",
				"     && APCMostRecents@Year == selectTidyRequiredColumns@Year,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> JoinMostRecentMetadata",
				"filter1 select(mapColumn(",
				"          ISSN_L,",
				"          wUID,",
				"          Publisher,",
				"          Title,",
				"          Source_title,",
				"          Model,",
				"          Year",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectTidyRequiredColumns",
				"select4 split(isNull(TitlesISSN_L),",
				"     disjoint: false) ~> SplitNewAndExisting@(NewRecords, ExistingRecords)",
				"surrogateKey2 derive(Updates = 0,",
				"          ISSN_L = TidyISSN_L,",
				"          wUID = TidywUID,",
				"          Source_title = TidySource_title,",
				"          Title = TidyTitle,",
				"          Model = TidyModel,",
				"          Publisher = TidyPublisher,",
				"          APC_ID = maxid + NewAPCID,",
				"          Year = TidyYear) ~> derivedColumn1",
				"SplitNewAndExisting@ExistingRecords derive(Updates = iif(isNull(TidyISSN_L),Updates,toShort(Updates+1)),",
				"          TitlesYear = iif(isNull(TidyISSN_L),TitlesYear,TidyYear),",
				"          TitleswUID = iif(isNull(TidyISSN_L),TitleswUID,toInteger(TidywUID)),",
				"          TitlesSource_title = iif(isNull(TidyISSN_L),TitlesSource_title,TidySource_title),",
				"          Titles_Title = iif(isNull(TidyISSN_L),Titles_Title,TidyTitle),",
				"          TitlesPublisher = iif(TitlesPublisher != TidyPublisher,TidyPublisher,TitlesPublisher)\r",
				"\r",
				"/* If there is change in Publisher in the recent year, update new publisher details in APCTitle(this is the master table) */,",
				"          TitlesModel = iif(isNull(TidyISSN_L),TitlesModel,TidyModel),",
				"          Change_publisher = iif(\r",
				"     isNull(TidyISSN_L), Change_publisher, \r",
				"     (\r",
				"      iif(TitlesPublisher != TidyPublisher,\r",
				"          toBoolean('1'),Change_publisher)\r",
				"     )\r",
				"   )\r",
				"\r",
				"\r",
				"/* iif(TitlesPublisher != TidyPublisher,toBoolean('1'),Change_publisher) */\r",
				"\r",
				"/* iif((isNull(TidyISSN_L) && TitlesPublisher != TidyPublisher),toBoolean('1'),Change_publisher) */) ~> UpdateExistingTitlesRecords",
				"join2 select(mapColumn(",
				"          RecentISSN_L = APCMostRecents@ISSN_L,",
				"          RecentYear = APCMostRecents@Year,",
				"          TidyISSN_L = selectTidyRequiredColumns@ISSN_L,",
				"          TidywUID = selectTidyRequiredColumns@wUID,",
				"          TidyPublisher = selectTidyRequiredColumns@Publisher,",
				"          TidyTitle = selectTidyRequiredColumns@Title,",
				"          TidySource_title = selectTidyRequiredColumns@Source_title,",
				"          TidyModel = selectTidyRequiredColumns@Model,",
				"          TidyYear = selectTidyRequiredColumns@Year,",
				"          APC_ID,",
				"          TitlesISSN_L = sourceAPCTitles@ISSN_L,",
				"          Title_ID,",
				"          TitlesSource_title = sourceAPCTitles@Source_title,",
				"          Titles_Title = sourceAPCTitles@Title,",
				"          TitlesPublisher = sourceAPCTitles@Publisher,",
				"          Publisher_Short,",
				"          Publisher_Short_OA,",
				"          TitlesYear = sourceAPCTitles@Year,",
				"          TitlesModel = sourceAPCTitles@Model,",
				"          APC,",
				"          Source_title_history,",
				"          Title_history,",
				"          Publisher_history,",
				"          Publisher_history_OA,",
				"          Year_history,",
				"          ID_history,",
				"          TitleswUID = sourceAPCTitles@wUID,",
				"          Contiguous,",
				"          Updates,",
				"          Child_records,",
				"          Change_publisher",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select4",
				"sourceAPCTitles aggregate(maxid = max(APC_ID)) ~> aggregate1",
				"aggregate1 select(mapColumn(",
				"          maxid",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select5",
				"UpdateExistingTitlesRecords select(mapColumn(",
				"          APC_ID,",
				"          ISSN_L = TitlesISSN_L,",
				"          Title_ID,",
				"          Source_title = TitlesSource_title,",
				"          Title = Titles_Title,",
				"          Publisher = TitlesPublisher,",
				"          Publisher_Short,",
				"          Publisher_Short_OA,",
				"          Year = TitlesYear,",
				"          Model = TitlesModel,",
				"          APC,",
				"          Source_title_history,",
				"          Title_history,",
				"          Publisher_history,",
				"          Publisher_history_OA,",
				"          Year_history,",
				"          ID_history,",
				"          wUID = TitleswUID,",
				"          Contiguous,",
				"          Updates,",
				"          Child_records,",
				"          Change_publisher",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select6",
				"derivedColumn1 select(mapColumn(",
				"          APC_ID,",
				"          Title_ID,",
				"          Publisher_Short,",
				"          Publisher_Short_OA,",
				"          APC,",
				"          Source_title_history,",
				"          Title_history,",
				"          Publisher_history,",
				"          Publisher_history_OA,",
				"          Year_history,",
				"          ID_history,",
				"          Contiguous,",
				"          Updates,",
				"          Child_records,",
				"          Change_publisher,",
				"          ISSN_L,",
				"          wUID,",
				"          Source_title,",
				"          Title,",
				"          Model,",
				"          Publisher,",
				"          Year",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select7",
				"select7, select6 union(byName: true)~> union1",
				"SplitNewAndExisting@NewRecords, select5 join(true(),",
				"     joinType:'cross',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"JoinMostRecentMetadata, sourceAPCTitles join(selectTidyRequiredColumns@ISSN_L == sourceAPCTitles@ISSN_L,",
				"     joinType:'outer',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join2",
				"join1 select(mapColumn(",
				"          RecentISSN_L,",
				"          RecentYear,",
				"          TidyISSN_L,",
				"          TidywUID,",
				"          TidyPublisher,",
				"          TidyTitle,",
				"          TidySource_title,",
				"          TidyModel,",
				"          TidyYear,",
				"          APC_ID,",
				"          TitlesISSN_L,",
				"          Title_ID,",
				"          TitlesSource_title,",
				"          Titles_Title,",
				"          TitlesPublisher,",
				"          Publisher_Short,",
				"          Publisher_Short_OA,",
				"          TitlesYear,",
				"          TitlesModel,",
				"          APC,",
				"          Source_title_history,",
				"          Title_history,",
				"          Publisher_history,",
				"          Publisher_history_OA,",
				"          Year_history,",
				"          ID_history,",
				"          TitleswUID,",
				"          Contiguous,",
				"          Updates,",
				"          Child_records,",
				"          Change_publisher,",
				"          maxid",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select8",
				"select8 keyGenerate(output(NewAPCID as long),",
				"     startAt: 1L,",
				"     stepValue: 1L) ~> surrogateKey2",
				"union1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          APC_ID as string,",
				"          ISSN_L as string,",
				"          Title_ID as string,",
				"          Source_title as string,",
				"          Title as string,",
				"          Publisher as string,",
				"          Publisher_Short as string,",
				"          Publisher_Short_OA as string,",
				"          Year as string,",
				"          Model as string,",
				"          APC as string,",
				"          Source_title_history as string,",
				"          Title_history as string,",
				"          Publisher_history as string,",
				"          Publisher_history_OA as string,",
				"          Year_history as string,",
				"          ID_history as string,",
				"          wUID as string,",
				"          Contiguous as string,",
				"          Updates as string,",
				"          Child_records as string,",
				"          Change_publisher as string",
				"     ),",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkAPCTitles"
			]
		}
	}
}