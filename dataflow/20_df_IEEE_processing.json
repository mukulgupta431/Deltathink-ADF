{
	"name": "20_df_IEEE_processing",
	"properties": {
		"folder": {
			"name": "apc/bronze to silver/Misc"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_IEEE_bronze_kbart",
						"type": "DatasetReference"
					},
					"name": "sourceKbart"
				},
				{
					"dataset": {
						"referenceName": "ds_IEEE_bronze_hybrid_journals",
						"type": "DatasetReference"
					},
					"name": "sourceHybrid"
				},
				{
					"dataset": {
						"referenceName": "ds_IEEE_bronze_societyTable",
						"type": "DatasetReference"
					},
					"name": "sourceSocietyTable"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_IEEE_silver_all_journals",
						"type": "DatasetReference"
					},
					"name": "sinkList1AllJournal"
				},
				{
					"dataset": {
						"referenceName": "ds_IEEE_silver_oa_journals",
						"type": "DatasetReference"
					},
					"name": "sinkList2"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "select2"
				},
				{
					"name": "filterNonSerial"
				},
				{
					"name": "lookupSocietyTable"
				}
			],
			"scriptLines": [
				"source(output(",
				"          publication_title as string,",
				"          print_identifier as string,",
				"          online_identifier as string,",
				"          date_first_issue_online as short,",
				"          num_first_vol_online as string,",
				"          num_first_issue_online as string,",
				"          date_last_issue_online as short,",
				"          num_last_vol_online as string,",
				"          num_last_issue_online as string,",
				"          title_url as string,",
				"          first_author as string,",
				"          title_id as integer,",
				"          embargo_info as string,",
				"          coverage_depth as string,",
				"          notes as string,",
				"          publisher_name as string,",
				"          publication_type as string,",
				"          date_monograph_published_print as string,",
				"          date_monograph_published_online as string,",
				"          monograph_volume as string,",
				"          monograph_edition as string,",
				"          first_editor as string,",
				"          parent_publication_title_id as string,",
				"          preceding_publication_title_id as string,",
				"          access_type as string,",
				"          subtype as string,",
				"          subjects as string,",
				"          frequency as short,",
				"          aspp as string,",
				"          iel as string,",
				"          ibm as string,",
				"          tup as string,",
				"          biai as string,",
				"          mitp as string,",
				"          nokia_bell_labs as string,",
				"          oa as string,",
				"          stem10 as string,",
				"          stem25 as string,",
				"          stem45 as string,",
				"          smpteall as string,",
				"          smptejnl as string,",
				"          agu as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceKbart",
				"source(output(",
				"          {Publication Acronym} as string,",
				"          {Publication Title} as string,",
				"          {Open Access Type} as string,",
				"          ISSN as string,",
				"          eISSN as string,",
				"          Index as string,",
				"          {Journal Impact Factor (JIF)} as double,",
				"          {5-Year Impact Factor} as double,",
				"          {Quartile (JIF)} as string,",
				"          JCI as double,",
				"          Eigenfactor as double,",
				"          {Article Influence Score (AIS)} as double,",
				"          CiteScore as double,",
				"          title_url as string,",
				"          title_id as integer,",
				"          apc as short",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceHybrid",
				"source(output(",
				"          Abbreviation as string,",
				"          {Full name} as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceSocietyTable",
				"lookupSocietyTable derive(Publisher = iif(:society_v == 'IET', :society_v ,:publisher_V),",
				"          ISSN1 = trim(online_identifier),",
				"          ISSN2 = trim(print_identifier),",
				"          Title = replace(trim(publication_title),', including the Proceedings of the Wireless Section of the Institution',''),",
				"          Source = :source_v,",
				"          Model = toString(null()),",
				"          {Model Notes} = iif(publication_title == 'Engineering & Technology', 'DELETE - trade magazine',",
				"    iif(",
				"        in(['OUP','MIT Press','OSA'],publisher_name),concat('DELETE - covered by ',publisher_name),",
				"        ''",
				"        )",
				"    )",
				"",
				"/* =IF(OR([@[publisher_name]]=\"OUP\",[@[publisher_name]]=\"MIT Press\",[@[publisher_name]]=\"OSA\"),\"DELETE - covered by \"&[@[publisher_name]],IF([@Title]=\"Engineering & Technology\", \"DELETE - trade magazine\",\"\")) */,",
				"          APC = toString(null()),",
				"          Currency = toString(null()),",
				"          {License Types} = toString(null()),",
				"          Year = :year_v,",
				"          PublisherID = title_id,",
				"          JoiningID = title_id,",
				"          Imprint = iif(in(['OUP','MIT Press','TUP','River Publishers'],publisher_name),:society_v,''),",
				"          Society = :society_v,",
				"          year_v := '2025',",
				"          Model_v := case(not(isNull(online_identifier)),\"Fully OA\",'Hybrid'),",
				"          publisher_V := 'IEEE',",
				"          source_v := 'Publisher Price List',",
				"          APC_v := 3874,",
				"          society_v := iif(",
				"    publication_title =='Journal of Optical Communications and Networking','OSA',",
				"    iif(",
				"        isNull(Abbreviation),publisher_name,{Full name}",
				"        )",
				"    )) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          Publisher,",
				"          ISSN1,",
				"          ISSN2,",
				"          Title,",
				"          Source,",
				"          Model,",
				"          {Model Notes},",
				"          APC,",
				"          Currency,",
				"          {License Types},",
				"          Year,",
				"          PublisherID,",
				"          JoiningID,",
				"          Imprint,",
				"          Society",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"sourceHybrid derive(Publisher = :publisher_V,",
				"          ISSN1 = trim(eISSN),",
				"          ISSN2 = trim(ISSN),",
				"          Title = replace(trim({Publication Title}),', including the Proceedings of the Wireless Section of the Institution',''),",
				"          Source = :source_v,",
				"          Model = case({Open Access Type} == 'Full Open Access','Fully OA',",
				"     case({Open Access Type} =='Hybrid Open Access','Hybrid',",
				"            case({Open Access Type} =='No Open Access','None',''",
				"                )",
				"        )",
				"    ),",
				"          {Model Notes} = toString(null()),",
				"          APC = apc,",
				"          Currency = iif(not(isNull(apc)),'USD',''),",
				"          {License Types} = toString(null()),",
				"          Year = :year_v,",
				"          PublisherID = :joiningId_v,",
				"          JoiningID = :joiningId_v,",
				"          Imprint = toString(null()),",
				"          Society = toString(null()),",
				"          year_v := '2025',",
				"          publisher_V := 'IEEE',",
				"          source_v := 'Publisher Price List',",
				"          APC_v := apc,",
				"          society_v := toString(null()),",
				"          joiningId_v := coalesce(eISSN,ISSN)) ~> derivedColumn2",
				"derivedColumn2 select(mapColumn(",
				"          Publisher,",
				"          ISSN1,",
				"          ISSN2,",
				"          Title,",
				"          Source,",
				"          Model,",
				"          {Model Notes},",
				"          APC = derivedColumn2@APC,",
				"          Currency,",
				"          {License Types},",
				"          Year,",
				"          PublisherID,",
				"          JoiningID,",
				"          Imprint,",
				"          Society",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"sourceKbart filter(isNull(date_last_issue_online) || date_last_issue_online == 2023) ~> filterNonSerial",
				"filterNonSerial, sourceSocietyTable lookup(publisher_name == Abbreviation,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookupSocietyTable",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkList1AllJournal",
				"select2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkList2"
			]
		}
	}
}