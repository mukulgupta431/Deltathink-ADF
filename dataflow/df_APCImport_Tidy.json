				}
			],
			"scriptLines": [
				"source(output(",
				"          ISSN1 as string,",
				"          ISSN2 as string,",
				"          Title as string,",
				"          Source as string,",
				"          Model as string,",
				"          {Model Notes} as string,",
				"          APC as string,",
				"          Currency as string,",
				"          {License Types} as string,",
				"          Year as short,",
				"          PublisherID as string,",
				"          JoiningID as string,",
				"          Imprint as string,",
				"          Society as string,",
				"          DAO as integer,",
				"          Publisher as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     partitionRootPath: 'gold/import1/') ~> source1",
				"source(output(",
				"          ISSN1 as string,",
				"          ISSN2 as string,",
				"          Title as string,",
				"          Source as string,",
				"          Model as string,",
				"          {Model Notes} as string,",
				"          APC as string,",
				"          Currency as string,",
				"          {License Types} as string,",
				"          Year as short,",
				"          PublisherID as string,",
				"          JoiningID as string,",
				"          Imprint as string,",
				"          Society as string,",
				"          DAO as integer,",
				"          Publisher as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     partitionRootPath: 'gold/import2/') ~> source2",
				"source(output(",
				"          Idx as string,",
				"          Name_Raw as string,",
				"          Name_Match as string,",
				"          Name_Punct as string,",
				"          Name_Abbrev as string,",
				"          Name_Clean as string,",
				"          Name_Abbrev_OLD as string,",
				"          Source as string,",
				"          Notes as string,",
				"          done as string,",
				"          bak as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source3",
				"source(output(",
				"          Publisher_Raw as string,",
				"          Publisher_Short as string,",
				"          Imprint_OA as string,",
				"          DAO as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source4",
				"source(output(",
				"          Publisher_Short as string,",
				"          Definitive_Name as string,",
				"          Parent_Publisher as string,",
				"          In_Sample as boolean,",
				"          In_Survey as boolean,",
				"          Society as boolean,",
				"          University as boolean,",
				"          OA_Type as string,",
				"          OA_Year as short",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source5",
				"derivedColumn1, derivedColumn2 join(source1@JoiningID == source2@JoiningID",
				"     && source1@Year == source2@Year",
				"     && source1@Publisher == source2@Publisher",
				"     && source1@DAO == source2@DAO,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"derivedColumn1, derivedColumn2 join(source1@JoiningID == source2@JoiningID",
				"     && source1@Year == source2@Year",
				"     && source1@Publisher == source2@Publisher",
				"     && source1@DAO == source2@DAO,",
				"     joinType:'right',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join2",
				"source1 derive(wUID = toString(null()),",
				"          TJ = toString(null()),",
				"          Audit = toString(null()),",
				"          Old_Table = toString(null()),",
				"          Old_wUID = toString(null()),",
				"          Old_Year = toString(null())) ~> derivedColumn1",
				"source2 derive(wUID = toString(null()),",
				"          TJ = toString(null()),",
				"          Audit = toString(null()),",
				"          Old_Table = toString(null()),",
				"          Old_wUID = toString(null()),",
				"          Old_Year = toString(null())) ~> derivedColumn2",
				"join1 derive(Import1ID = derivedColumn1@wUID,",
				"          Import2ID = derivedColumn2@wUID,",
				"          Publisher = coalesce(source1@Publisher, source2@Publisher),",
				"          ISSN1 = coalesce(source1@ISSN1,source2@ISSN1),",
				"          ISSN2 = iif(!isNull(source1@ISSN2), source1@ISSN2, ",
				"    iif(source2@ISSN1 == source1@ISSN1, toString(null()), ",
				"        iif(source2@ISSN2 == source1@ISSN1, toString(null()), source2@ISSN2)",
				"    )",
				"),",
				"          Title = coalesce(source1@Title,source2@Title),",
				"          Source = coalesce(source1@Source,source2@Source),",
				"          Model = coalesce(source2@Model,source1@Model),",
				"          Model_Notes = coalesce(source1@{Model Notes},source2@{Model Notes}),",
				"          APC = coalesce(source2@APC,source1@APC),",
				"          Currency = coalesce(source2@Currency,source1@Currency),",
				"          Year = source1@Year,",
				"          DAO = source1@DAO,",
				"          LicenseType = coalesce(source2@{License Types},source1@{License Types}),",
				"          PublisherID = coalesce(source1@PublisherID, source2@PublisherID),",
				"          JoiningID = coalesce(source1@JoiningID, source2@JoiningID),",
				"          Imprint = coalesce(source1@Imprint, source2@Imprint),",
				"          Society = coalesce(source1@Society, source2@Society),",
				"          TJ = derivedColumn2@TJ,",
				"          Audit = derivedColumn1@Audit,",
				"          Import1_Old_Table = derivedColumn1@Old_Table,",
				"          Import1_Old_wUID = derivedColumn1@Old_wUID,",
				"          Import1_Old_Year = derivedColumn1@Old_Year,",
				"          Present_via = coalesce(source2@JoiningID,'APCimport1 only'),",
				"          Publication_Data_Year = source1@Year,",
				"          Metrics_Data_Year = source1@Year,",
				"          Import2_Old_Table = derivedColumn2@Old_Table,",
				"          Import2_Old_wUID = derivedColumn2@Old_wUID,",
				"          Import2_Old_Year = derivedColumn2@Old_Year,",
				"          ISSN_X = toString(null()),",
				"          ISSNs_in_order = toString(null()),",
				"          IY = toString(null()),",
				"          IYP = toString(null())) ~> derivedColumn3",
				"derivedColumn3 select(mapColumn(",
				"          Import1ID,",
				"          Import2ID,",
				"          Publisher,",
				"          ISSN1,",
				"          ISSN2,",
				"          Title,",
				"          Source,",
				"          Model,",
				"          Model_Notes,",
				"          APC,",
				"          Currency,",
				"          Year,",
				"          DAO,",
				"          LicenseType,",
				"          PublisherID,",
				"          JoiningID,",
				"          Imprint,",
				"          Society,",
				"          TJ,",
				"          Audit,",
				"          Import1_Old_Table,",
				"          Import1_Old_wUID,",
				"          Import1_Old_Year,",
				"          Present_via,",
				"          Publication_Data_Year,",
				"          Metrics_Data_Year,",
				"          Import2_Old_Table,",
				"          Import2_Old_wUID,",
				"          Import2_Old_Year,",
				"          ISSNs_in_order,",
				"          ISSN_X,",
				"          IY,",
				"          IYP",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"join2 filter(isNull(source1@JoiningID)) ~> filter1",
				"filter1 derive(Import1ID = derivedColumn1@wUID,",
				"          Import2ID = derivedColumn2@wUID,",
				"          Present_via = 'APCimport2 only',",
				"          Publisher = source2@Publisher,",
				"          ISSN1 = source2@ISSN1,",
				"          ISSN2 = source2@ISSN2,",
				"          Title = source2@Title,",
				"          Source = source2@Source,",
				"          Model = source2@Model,",
				"          Model_Notes = source2@{Model Notes},",
				"          APC = source2@APC,",
				"          Currency = source2@Currency,",
				"          Year = source2@Year,",
				"          DAO = source2@DAO,",
				"          LicenseType = source2@{License Types},",
				"          PublisherID = source2@PublisherID,",
				"          JoiningID = source2@JoiningID,",
				"          Imprint = source2@Imprint,",
				"          Society = source2@Society,",
				"          TJ = derivedColumn2@TJ,",
				"          Audit = derivedColumn2@Audit,",
				"          Import1_Old_Table = derivedColumn2@Old_Table,",
				"          Import1_Old_wUID = derivedColumn2@Old_wUID,",
				"          Import1_Old_Year = derivedColumn2@Old_Year,",
				"          Publication_Data_Year = source2@Year,",
				"          Metrics_Data_Year = source2@Year-2,",
				"          Import2_Old_Table = toString(null())",
				"/* Refer line number 217 -219 in APC Import Tidy.sql */,",
				"          Import2_Old_wUID = toString(null()) /* Refer line number 217 -219 in APC Import Tidy.sql */,",
				"          Import2_Old_Year = toString(null()) /* Refer line number 217 -219 in APC Import Tidy.sql */,",
				"          ISSN_X = toString(null()),",
				"          ISSNs_in_order = toString(null()),",
				"          IY = toString(null()),",
				"          IYP = toString(null())) ~> derivedColumn4",
				"derivedColumn4 select(mapColumn(",
				"          Import1ID,",
				"          Import2ID,",
				"          Publisher,",
				"          ISSN1,",
				"          ISSN2,",
				"          Title,",
				"          Source,",
				"          Model,",
				"          Model_Notes,",
				"          APC,",
				"          Currency,",
				"          Year,",
				"          DAO,",
				"          LicenseType,",
				"          PublisherID,",
				"          JoiningID,",
				"          Imprint,",
				"          Society,",
				"          TJ,",
				"          Audit,",
				"          Import1_Old_Table,",
				"          Import1_Old_wUID,",
				"          Import1_Old_Year,",
				"          Present_via,",
				"          Publication_Data_Year,",
				"          Metrics_Data_Year,",
				"          Import2_Old_Table,",
				"          Import2_Old_wUID,",
				"          Import2_Old_Year,",
				"          ISSNs_in_order,",
				"          ISSN_X,",
				"          IY,",
				"          IYP",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"select2, select1 union(byName: true)~> union1",
				"window1 select(mapColumn(",
				"          Import1ID,",
				"          Import2ID,",
				"          Publisher,",
				"          ISSN1,",
				"          ISSN2,",
				"          Title,",
				"          Source = union1@Source,",
				"          Model,",
				"          Model_Notes,",
				"          APC,",
				"          Currency,",
				"          Year,",
				"          DAO,",
				"          LicenseType,",
				"          PublisherID,",
				"          JoiningID,",
				"          Imprint,",
				"          Society,",
				"          TJ,",
				"          Audit,",
				"          Import1_Old_Table,",
				"          Import1_Old_wUID,",
				"          Import1_Old_Year,",
				"          Present_via,",
				"          Publication_Data_Year,",
				"          Metrics_Data_Year,",
				"          Import2_Old_Table,",
				"          Import2_Old_wUID,",
				"          Import2_Old_Year,",
				"          ISSNs_in_order,",
				"          ISSN_X,",
				"          IY,",
				"          IYP,",
				"          Source_title,",
				"          Idx,",
				"          Name_Raw,",
				"          Name_Match,",
				"          Name_Punct,",
				"          Name_Abbrev,",
				"          Name_Clean,",
				"          Name_Abbrev_OLD,",
				"          Source = source3@Source,",
				"          Notes,",
				"          done,",
				"          bak,",
				"          wUID",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"union1 derive(Year = iif(Year < 2024 ,Year+1,toInteger(Year)),",
				"          Model = iif(isNull(Model) || Model == '0' || Model =='' || Model == 'n/a',trim('None'),trim(Model)),",
				"          ISSN_X = :ISSN_X_v,",
				"          ISSN1 = coalesce(:ISSN1_v,:ISSN_X_v),",
				"          ISSN2 = iif(ISSN2 == :ISSN1_v, toString(null()), ISSN2),",
				"          APC = replace(replace(replace(APC, '$',''),',',''),'-',''),",
				"          ISSNs_in_order = replace(coalesce(concat(least(ISSN1,ISSN2),greatest(ISSN1,ISSN2)),ISSN1,ISSN2,''),'-',''),",
				"          IY = concat(ISSNs_in_order,toString(Year)),",
				"          IYP = concat(ISSNs_in_order,toString(Year),Publisher),",
				"          Currency = iif(Currency == '' || Currency == 'N/A',toString(null()),Currency),",
				"          Title = :Title_v,",
				"          Source_title = :Title_v,",
				"          ISSN_X_v := concat(left(soundex(Title),4),'-',right(soundex(Title),4)),",
				"          ISSN1_v := iif(isNull(ISSN1) && not(isNull(ISSN2)), ISSN2, ISSN1),",
				"          Title_v := trim(replace(replace(replace(replace(replace(replace(replace(replace(replace(replace(replace(replace",
				"    (replace(replace(replace(replace(replace(replace(replace(replace(replace(replace(replace",
				"    (replace(Title, '√≠','í'),'√≥','ó'),'√ß','ç'),'√©','é'),'√£','ã'),'√™','ê'),'√®','è'),'√ç','i'), ",
				"    '√±','ñ'),'√°','á'),'√â','É'),'√∫','ú'),'√º','ü'),'&#257;','ā'),'&#333;','ō'),'&#39;','\\''),'®',''),",
				"    '&ndash;','-'),'&mdash','-'),'&amp;','&'),'™',''), ' ',' '), '  ',' '),'  ',' '))",
				"",
				"/* -- Remove diacriticals (side effect of using PDFs to populate some of the source spreadsheets)",
				"     -- NOTE: here we rely on Mac's characterset in Querious handling the diacritcals below. See Character set analysis for more on this.",
				"     -- √X are Unicode misinterpreted as Mac-Roman, typically in APCimport2: https://stackoverflow.com/questions/15283189/how-to-decode-these-characters-√-√-√≠",
				"     -- *** FULL LIST of these at the end of this query...these are what we spotted",
				"     -- *** ADD AS NEEDED EACH YEAR - see check just below */) ~> derivedColumn5",
				"derivedColumn5 filter(not(isNull(Title))) ~> filter2",
				"filter2, source3 lookup(Source_title == Name_Raw,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"lookup1 derive(Title = coalesce(Name_Clean,Source_title)) ~> APCTidyAll",
				"select3 derive(condition_where = :modelNotes_Delete_v,",
				"          condition_gp = :gpBy_v,",
				"          modelNotes_Delete_v := iif(startsWith(Model_Notes, 'DELETE - '), 1e7, toFloat(0)) + wUID,",
				"          gpBy_v := iif(isNull(Import1ID), wUID + 1e7, toFloat(Import1ID))) ~> derivedColumn7",
				"derivedColumn7 aggregate(groupBy(Year,",
				"          condition_gp),",
				"     subquery_output = min(condition_where)) ~> aggregate1",
				"select3 derive(APC_ID = wUID,",
				"          Title_ID = toString(null()),",
				"          ISSN_L = ISSN1,",
				"          Publisher_Short = Publisher,",
				"          Publisher_Short_OA = Publisher,",
				"          Publisher_OA_type = 'Mixed Model',",
				"          Unique_title = Source_title,",
				"          Currency_Data_Year = Year-1,",
				"          Inflation_Data_Year = Year-1,",
				"          years_zero_APC = 0,",
				"          last_year_APC = APC,",
				"          last_year_model = Model,",
				"          next_year_model = Model) ~> APCTidy",
				"APCTidy, aggregate1 lookup(wUID == subquery_output,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup2",
				"derivedColumn8 select(mapColumn(",
				"          APC_ID,",
				"          Title_ID,",
				"          ISSN_L,",
				"          Publisher_Short,",
				"          Publisher_Short_OA,",
				"          Publisher_OA_type,",
				"          Unique_title,",
				"          wUID,",
				"          Import1ID,",
				"          Import2ID,",
				"          Publisher,",
				"          ISSN1,",
				"          ISSN2,",
				"          Title,",
				"          Source_title,",
				"          Source,",
				"          Model,",
				"          Model_Notes,",
				"          APC,",
				"          Currency,",
				"          Year = select3@Year,",
				"          DAO = select3@DAO,",
				"          LicenseType,",
				"          PublisherID,",
				"          JoiningID,",
				"          Imprint,",
				"          Society,",
				"          TJ,",
				"          Audit,",
				"          Import1_Old_Table,",
				"          Import1_Old_wUID,",
				"          Import1_Old_Year,",
				"          Present_via,",
				"          Import2_Old_Table,",
				"          Import2_Old_wUID,",
				"          Import2_Old_Year,",
				"          ISSN_X,",
				"          ISSNs_in_order,",
				"          IY,",
				"          IYP,",
				"          Publication_Data_Year,",
				"          Metrics_Data_Year,",
				"          Currency_Data_Year,",
				"          Inflation_Data_Year,",
				"          last_year_APC,",
				"          years_zero_APC,",
				"          last_year_model,",
				"          next_year_model",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectAPCTidy",
				"lookup2, source4 lookup(Imprint == Publisher_Raw,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup3",
				"lookup4 derive(Publisher_Short_OA = coalesce(iifNull(source4@Imprint_OA,''),APCTidy@Publisher_Short),",
				"          Imprint = iif(Imprint == '' || Imprint == '0' || Imprint == '(Publisher)' || Imprint == '#N/A',toString(null()),Imprint)",
				"",
				"/* iif(in(['','0','(Publisher)','#N/A'],Imprint),toString(null(),Imprint) */,",
				"          Society = iif(in(['0', '', '-', '#N/A', '(Publisher)', 'Publisher'],select3@Society),toString(null()), select3@Society),",
				"          Currency = iif(Currency == '' || Currency == 'N/A', toString(null()),Currency),",
				"          Publisher = Definitive_Name,",
				"          Publisher_Short = source4@Publisher_Short,",
				"          Publisher_OA_type = iif(select3@Year >= OA_Year,OA_Type,'Mixed Model')) ~> derivedColumn8",
				"source5, source4 join(source5@Publisher_Short == source4@Publisher_Short,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join3",
				"join3 select(mapColumn(",
				"          Publisher_Short = source5@Publisher_Short,",
				"          Definitive_Name,",
				"          Parent_Publisher,",
				"          In_Sample,",
				"          In_Survey,",
				"          Society,",
				"          University,",
				"          OA_Type,",
				"          OA_Year,",
				"          Publisher_Raw,",
				"          Publisher_Short = source4@Publisher_Short,",
				"          Imprint_OA,",
				"          DAO",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select4",
				"APCTidyAll window(asc(Publisher, false),",
				"     wUID = rowNumber()) ~> window1",
				"lookup3, select4 lookup(Publisher == select4@Publisher_Raw,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup4",
				"selectAPCTidy sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkAPCTidy"
			]
		}
	}
}