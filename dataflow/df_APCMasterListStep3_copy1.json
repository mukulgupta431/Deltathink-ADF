{
	"name": "df_APCMasterListStep3_copy1",
	"properties": {
		"folder": {
			"name": "apc/silver to gold/APCMasterList"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_APCMaster_APCTitles",
						"type": "DatasetReference"
					},
					"name": "sourceAPCTitles"
				},
				{
					"dataset": {
						"referenceName": "ds_APCImport_Tidy",
						"type": "DatasetReference"
					},
					"name": "sourceAPCTidy"
				},
				{
					"dataset": {
						"referenceName": "ds_APC_ISSNs",
						"type": "DatasetReference"
					},
					"name": "sourceAPCISSNs"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_APCMaster_APCTitles",
						"type": "DatasetReference"
					},
					"name": "sinkAPCTitles"
				},
				{
					"dataset": {
						"referenceName": "ds_APC_ISSNs",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "aggregate1"
				},
				{
					"name": "DeriveHistoryTable"
				},
				{
					"name": "selectRequiredColumns"
				},
				{
					"name": "joinHistoryAPCTitles"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "selectTitlesColumns"
				},
				{
					"name": "joinAPCIssnsAPCTidy"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "selectAPCISSNsColumns"
				}
			],
			"scriptLines": [
				"source(output(",
				"          APC_ID as string,",
				"          ISSN_L as string,",
				"          Title_ID as string,",
				"          Source_title as string,",
				"          Title as string,",
				"          Publisher as string,",
				"          Publisher_Short as string,",
				"          Publisher_Short_OA as string,",
				"          Year as string,",
				"          Model as string,",
				"          APC as string,",
				"          Source_title_history as string,",
				"          Title_history as string,",
				"          Publisher_history as string,",
				"          Publisher_history_OA as string,",
				"          Year_history as string,",
				"          ID_history as string,",
				"          wUID as string,",
				"          Contiguous as string,",
				"          Updates as string,",
				"          Child_records as string,",
				"          Change_publisher as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceAPCTitles",
				"source(output(",
				"          APC_ID as short,",
				"          Title_ID as string,",
				"          ISSN_L as string,",
				"          Publisher_Short as string,",
				"          Publisher_Short_OA as string,",
				"          Publisher_OA_type as string,",
				"          Unique_title as string,",
				"          wUID as short,",
				"          Import1ID as string,",
				"          Import2ID as string,",
				"          Publisher as string,",
				"          ISSN1 as string,",
				"          ISSN2 as string,",
				"          Title as string,",
				"          Source_title as string,",
				"          Source as string,",
				"          Model as string,",
				"          Model_Notes as string,",
				"          APC as string,",
				"          Currency as string,",
				"          Year as short,",
				"          DAO as short,",
				"          LicenseType as string,",
				"          PublisherID as string,",
				"          JoiningID as string,",
				"          Imprint as string,",
				"          Society as string,",
				"          TJ as string,",
				"          Audit as string,",
				"          Import1_Old_Table as string,",
				"          Import1_Old_wUID as string,",
				"          Import1_Old_Year as string,",
				"          Present_via as string,",
				"          Import2_Old_Table as string,",
				"          Import2_Old_wUID as string,",
				"          Import2_Old_Year as string,",
				"          ISSN_X as string,",
				"          ISSNs_in_order as string,",
				"          IY as string,",
				"          IYP as string,",
				"          Publication_Data_Year as short,",
				"          Metrics_Data_Year as short,",
				"          Currency_Data_Year as short,",
				"          Inflation_Data_Year as short,",
				"          last_year_APC as string,",
				"          years_zero_APC as boolean,",
				"          last_year_model as string,",
				"          next_year_model as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceAPCTidy",
				"source(output(",
				"          APC_ID as short,",
				"          wUID as short,",
				"          ISSN as string,",
				"          ISSN_L as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceAPCISSNs",
				"sourceAPCTidy aggregate(groupBy(ISSN_L),",
				"     cnt_dummy = count(ISSN_L),",
				"          titleList = collect(concat(Title,'|',toString(Year)))",
				"",
				"/* collect(Title) collectUnique(Title) */,",
				"          sourceList = collect(concat(Source_title,'|',toString(Year))),",
				"          yearList = collect(concat(toString(Year),'|',toString(Year))),",
				"          pubList = collect(concat(Publisher_Short,'|',toString(Year))),",
				"          poaList = collect(concat(Publisher_Short_OA,'|',toString(Year))),",
				"          idList = collect(concat(toString(wUID),'|',toString(Year))),",
				"          cgu = countIf(true(), 1) == (max(toLong(Year)) - min(toLong(Year)) + 1)) ~> aggregate1",
				"aggregate1 derive(t = concat(split(sort(titleList, true())[1], '|')[1])",
				"/* concat(toString(distinct(titleList))) */,",
				"          st = concat(split(sort(sourceList, true())[1], '|')[1]),",
				"          y = concat(split(sort(yearList, true())[1], '|')[1]),",
				"          p = concat(split(sort(pubList, true())[1], '|')[1]),",
				"          poa = concat(split(sort(poaList, true())[1], '|')[1]),",
				"          IDs = concat(split(sort(idList, true())[1], '|')[1])) ~> DeriveHistoryTable",
				"DeriveHistoryTable select(mapColumn(",
				"          ISSN_L,",
				"          cgu,",
				"          t,",
				"          st,",
				"          y,",
				"          p,",
				"          poa,",
				"          IDs",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRequiredColumns",
				"selectRequiredColumns, sourceAPCTitles join(selectRequiredColumns@ISSN_L == sourceAPCTitles@ISSN_L,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinHistoryAPCTitles",
				"joinHistoryAPCTitles derive(Title_history = t,",
				"          Source_title_history = st,",
				"          Year_history = y,",
				"          Publisher_history = p,",
				"          Publisher_history_OA = poa,",
				"          ID_history = IDs,",
				"          Contiguous = cgu) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          APC_ID,",
				"          ISSN_L = sourceAPCTitles@ISSN_L,",
				"          Title_ID,",
				"          Source_title,",
				"          Title,",
				"          Publisher,",
				"          Publisher_Short,",
				"          Publisher_Short_OA,",
				"          Year,",
				"          Model,",
				"          APC,",
				"          Source_title_history,",
				"          Title_history,",
				"          Publisher_history,",
				"          Publisher_history_OA,",
				"          Year_history,",
				"          ID_history,",
				"          wUID,",
				"          Contiguous,",
				"          Updates,",
				"          Child_records,",
				"          Change_publisher",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectTitlesColumns",
				"sourceAPCISSNs, sourceAPCTidy join(sourceAPCISSNs@ISSN_L == sourceAPCTidy@ISSN_L,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinAPCIssnsAPCTidy",
				"joinAPCIssnsAPCTidy derive(APC_ID = sourceAPCTidy@APC_ID) ~> derivedColumn2",
				"derivedColumn2 select(mapColumn(",
				"          APC_ID,",
				"          wUID = sourceAPCISSNs@wUID,",
				"          ISSN,",
				"          ISSN_L = sourceAPCISSNs@ISSN_L",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectAPCISSNsColumns",
				"selectTitlesColumns sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          APC_ID as string,",
				"          ISSN_L as string,",
				"          Title_ID as string,",
				"          Source_title as string,",
				"          Title as string,",
				"          Publisher as string,",
				"          Publisher_Short as string,",
				"          Publisher_Short_OA as string,",
				"          Year as string,",
				"          Model as string,",
				"          APC as string,",
				"          Source_title_history as string,",
				"          Title_history as string,",
				"          Publisher_history as string,",
				"          Publisher_history_OA as string,",
				"          Year_history as string,",
				"          ID_history as string,",
				"          wUID as string,",
				"          Contiguous as string,",
				"          Updates as string,",
				"          Child_records as string,",
				"          Change_publisher as string",
				"     ),",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkAPCTitles",
				"selectAPCISSNsColumns sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}