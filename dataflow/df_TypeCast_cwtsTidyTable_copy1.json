{
	"name": "df_TypeCast_cwtsTidyTable_copy1",
	"properties": {
		"folder": {
			"name": "MarketSizing"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_apc_Import_cwts_tidy",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "AzureMySqlcwtsTidyTable",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Idx as short,",
				"          ISSNs_as_stated as string,",
				"          ISSNs_in_order as string,",
				"          ISSN1_as_stated as string,",
				"          ISSNs_and_title as string,",
				"          CWTS_ID as string,",
				"          CWTS_ID_Last_Year as string,",
				"          Year_wUID as string,",
				"          Title as string,",
				"          Source_title as string,",
				"          Type as string,",
				"          Print_ISSN as string,",
				"          Electronic_ISSN as string,",
				"          ASJC_field_IDs as string,",
				"          Year as short,",
				"          Citing_source as boolean,",
				"          P as short,",
				"          IPP as double,",
				"          IPP_lower_bound_ as double,",
				"          IPP_upper_bound_ as double,",
				"          SNIP as double,",
				"          SNIP_lower_bound_ as double,",
				"          SNIP_upper_bound_ as double,",
				"          {%_self_cit} as string,",
				"          Avg_SNIP as string,",
				"          ISSNs_count as short,",
				"          ISSN_X as string,",
				"          ISSN1 as string,",
				"          ISSN2 as string,",
				"          Seq as short,",
				"          Rank as short,",
				"          dense_rank as short,",
				"          Quartile as string,",
				"          Best_Quartile as string,",
				"          Metrics_Data_Year as short,",
				"          Model as string,",
				"          inMarket as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"derivedColumn1 select(mapColumn(",
				"          Idx,",
				"          ISSNs_as_stated,",
				"          ISSNs_in_order,",
				"          ISSN1_as_stated,",
				"          ISSNs_and_title,",
				"          CWTS_ID,",
				"          CWTS_ID_Last_Year,",
				"          Year_wUID,",
				"          Title,",
				"          Source_title,",
				"          Type,",
				"          Print_ISSN,",
				"          Electronic_ISSN,",
				"          ASJC_field_IDs,",
				"          Year,",
				"          Citing_source,",
				"          P,",
				"          IPP,",
				"          IPP_lower_bound_,",
				"          IPP_upper_bound_,",
				"          SNIP,",
				"          SNIP_lower_bound_,",
				"          SNIP_upper_bound_,",
				"          {%_self_cit},",
				"          Avg_SNIP,",
				"          ISSNs_count,",
				"          ISSN_X,",
				"          ISSN1,",
				"          ISSN2,",
				"          Seq,",
				"          Rank,",
				"          dense_rank,",
				"          Quartile,",
				"          Best_Quartile,",
				"          Metrics_Data_Year,",
				"          Model,",
				"          inMarket",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"source1 derive(ISSNs_count = toInteger(ISSNs_count),",
				"          Seq = toInteger(Seq),",
				"          Rank = toInteger(Rank),",
				"          dense_rank = toInteger(dense_rank),",
				"          Citing_source = toInteger(iif(toString(Citing_source) == \"true\", 1, 0))\r",
				"/* toString(Citing_source)*/,",
				"          inMarket = toString(iif(toString(inMarket) == \"true\", 1, 0))) ~> derivedColumn1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          Idx as long,",
				"          ISSNs_as_stated as string,",
				"          ISSNs_in_order as string,",
				"          ISSN1_as_stated as string,",
				"          ISSNs_and_title as string,",
				"          CWTS_ID as string,",
				"          CWTS_ID_Last_Year as string,",
				"          Year_wUID as string,",
				"          Title as string,",
				"          Source_title as string,",
				"          Type as string,",
				"          Print_ISSN as string,",
				"          Electronic_ISSN as string,",
				"          ASJC_field_IDs as string,",
				"          Year as integer,",
				"          Citing_source as integer,",
				"          P as integer,",
				"          IPP as string,",
				"          IPP_lower_bound_ as string,",
				"          IPP_upper_bound_ as string,",
				"          SNIP as string,",
				"          SNIP_lower_bound_ as string,",
				"          SNIP_upper_bound_ as string,",
				"          {%_self_cit} as string,",
				"          Avg_SNIP as string,",
				"          ISSNs_count as long,",
				"          ISSN_X as string,",
				"          ISSN1 as string,",
				"          ISSN2 as string,",
				"          Seq as long,",
				"          Rank as long,",
				"          dense_rank as long,",
				"          Quartile as string,",
				"          Best_Quartile as string,",
				"          Metrics_Data_Year as integer,",
				"          Model as string,",
				"          inMarket as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}