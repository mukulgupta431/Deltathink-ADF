{
	"name": "df_APCImport2",
	"properties": {
		"folder": {
			"name": "apc/silver to gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_elsevier_silver_oa_journals",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "ds_springerNature_silver_oa_journals",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "ds_WoltersKluwerHealth_silver_oa_journals",
						"type": "DatasetReference"
					},
					"name": "source3"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_gold_APCImport2_2025",
						"type": "DatasetReference"
					},
					"name": "sinkAPCImport1"
				}
			],
			"transformations": [
				{
					"name": "union1"
				},
				{
					"name": "union2"
				},
				{
					"name": "union3"
				},
				{
					"name": "union4"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "filter1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Publisher as string,",
				"          ISSN1 as string,",
				"          ISSN2 as string,",
				"          Title as string,",
				"          Source as string,",
				"          Model as string,",
				"          {Model Notes} as string,",
				"          APC as string,",
				"          Currency as string,",
				"          Year as short,",
				"          PublisherID as string,",
				"          JoiningID as string,",
				"          Imprint as string,",
				"          Society as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          Publisher as string,",
				"          ISSN1 as string,",
				"          ISSN2 as string,",
				"          Title as string,",
				"          Source as string,",
				"          Model as string,",
				"          {Model Notes} as string,",
				"          APC as string,",
				"          Currency as string,",
				"          Year as short,",
				"          PublisherID as string,",
				"          JoiningID as string,",
				"          Imprint as string,",
				"          Society as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source(output(",
				"          Publisher as string,",
				"          ISSN1 as string,",
				"          ISSN2 as string,",
				"          Title as string,",
				"          Source as string,",
				"          Model as string,",
				"          {Model Notes} as string,",
				"          APC as string,",
				"          Currency as string,",
				"          Year as short,",
				"          PublisherID as string,",
				"          JoiningID as string,",
				"          Imprint as string,",
				"          Society as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source3",
				"source1, source2 union(byName: true)~> union1",
				"union1, source3 union(byName: true)~> union2",
				"union2 union(byName: true)~> union3",
				"union3 union(byName: true)~> union4",
				"union4 derive(ISSN1 = iif(",
				"    regexMatch(ISSN1, '[0-9]{4}-[0-9]{3}[0-9X]'),",
				"    iif(ISSN1 == '0000-0000','',translate(ISSN1,',.�ñ','')),",
				"    ''",
				"    ),",
				"          ISSN2 = iif(\r",
				"    regexMatch(ISSN2, '[0-9]{4}-[0-9]{3}[0-9X]'),\r",
				"    iif(ISSN2 == '0000-0000','',translate(ISSN2,',.�ñ','')),\r",
				"    ''\r",
				"    )) ~> derivedColumn1",
				"derivedColumn1 filter(not(isNull(Title)),",
				"     partitionBy('key',",
				"          0,",
				"          Year,",
				"          Publisher",
				"     )) ~> filter1",
				"filter1 select(mapColumn(",
				"          Publisher,",
				"          ISSN1,",
				"          ISSN2,",
				"          Title,",
				"          Source,",
				"          Model,",
				"          {Model Notes},",
				"          APC,",
				"          Currency,",
				"          Year,",
				"          PublisherID,",
				"          JoiningID,",
				"          Imprint,",
				"          Society",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('key',",
				"          0,",
				"          Year,",
				"          Publisher",
				"     )) ~> sinkAPCImport1"
			]
		}
	}
}