{
	"name": "df_APCMasterListStep2",
	"properties": {
		"folder": {
			"name": "apc/silver to gold/APCMasterList"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_APCMaster_APCTitles",
						"type": "DatasetReference"
					},
					"name": "sourceAPCTitles"
				},
				{
					"dataset": {
						"referenceName": "ds_APCImport_Tidy",
						"type": "DatasetReference"
					},
					"name": "sourceAPCTidy"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_APCMaster_APCTitles",
						"type": "DatasetReference"
					},
					"name": "sinkAPCTitles"
				},
				{
					"dataset": {
						"referenceName": "ds_APCImport_Tidy",
						"type": "DatasetReference"
					},
					"name": "sinkAPCTidy"
				}
			],
			"transformations": [
				{
					"name": "aggregate2"
				},
				{
					"name": "select8"
				},
				{
					"name": "join2"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "join3"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "selectTidyColumns"
				},
				{
					"name": "select1"
				},
				{
					"name": "select2"
				},
				{
					"name": "select9"
				},
				{
					"name": "selectToSinkTidy"
				}
			],
			"scriptLines": [
				"source(output(",
				"          APC_ID as short,",
				"          ISSN_L as string,",
				"          Title_ID as integer,",
				"          Source_title as string,",
				"          Title as string,",
				"          Publisher as string,",
				"          Publisher_Short as string,",
				"          Publisher_Short_OA as string,",
				"          Year as short,",
				"          Model as string,",
				"          APC as string,",
				"          Source_title_history as string,",
				"          Title_history as string,",
				"          Publisher_history as string,",
				"          Publisher_history_OA as string,",
				"          Year_history as string,",
				"          ID_history as string,",
				"          wUID as integer,",
				"          Contiguous as boolean,",
				"          Updates as short,",
				"          Child_records as short,",
				"          Change_publisher as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceAPCTitles",
