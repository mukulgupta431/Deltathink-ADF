				"          APC_ID as short,",
				"          Title_ID as string,",
				"          ISSN_L as string,",
				"          Publisher_Short as string,",
				"          Publisher_Short_OA as string,",
				"          Publisher_OA_type as string,",
				"          Unique_title as string,",
				"          wUID as short,",
				"          Import1ID as string,",
				"          Import2ID as string,",
				"          Publisher as string,",
				"          ISSN1 as string,",
				"          ISSN2 as string,",
				"          Title as string,",
				"          Source_title as string,",
				"          Source as string,",
				"          Model as string,",
				"          Model_Notes as string,",
				"          APC as string,",
				"          Currency as string,",
				"          Year as short,",
				"          DAO as short,",
				"          LicenseType as string,",
				"          PublisherID as string,",
				"          JoiningID as string,",
				"          Imprint as string,",
				"          Society as string,",
				"          TJ as string,",
				"          Audit as string,",
				"          Import1_Old_Table as string,",
				"          Import1_Old_wUID as string,",
				"          Import1_Old_Year as string,",
				"          Present_via as string,",
				"          Import2_Old_Table as string,",
				"          Import2_Old_wUID as string,",
				"          Import2_Old_Year as string,",
				"          ISSN_X as string,",
				"          ISSNs_in_order as string,",
				"          IY as string,",
				"          IYP as string,",
				"          Publication_Data_Year as short,",
				"          Metrics_Data_Year as short,",
				"          Currency_Data_Year as short,",
				"          Inflation_Data_Year as short,",
				"          last_year_APC as string,",
				"          years_zero_APC as boolean,",
				"          last_year_model as string,",
				"          next_year_model as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceAPCTidy",
				"selectTidyColumns aggregate(groupBy(ISSN_L = TidyISSN_L,",
				"          Year = TidyYear),",
				"     No_Of_Child_Records = count(TidyISSN_L)) ~> aggregate2",
				"aggregate2 select(skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select8",
				"select8, sourceAPCTitles join(select8@ISSN_L == sourceAPCTitles@ISSN_L",
				"     && select8@Year == sourceAPCTitles@Year,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join2",
				"join2 derive(Child_records = No_Of_Child_Records) ~> derivedColumn2",
				"select1, select2 join(TitlesISSN_L == TidyISSN_L,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join3",
				"join3 derive(TidyAPC_ID = TitlesAPC_ID,",
				"          TidyUnique_title = TitlesSource_title) ~> derivedColumn3",
				"derivedColumn3 select(mapColumn(",
				"          TidyAPC_ID,",
				"          TidyTitle_ID,",
				"          TidyISSN_L,",
				"          TidyPublisher_Short,",
				"          TidyPublisher_Short_OA,",
				"          TidyPublisher_OA_type,",
				"          TidyUnique_title,",
				"          TidywUID,",
				"          TidyImport1ID,",
				"          TidyImport2ID,",
				"          TidyPublisher,",
				"          TidyISSN1,",
				"          TidyISSN2,",
				"          TidyTitle,",
				"          TidySource_title,",
				"          TidySource,",
				"          TidyModel,",
				"          TidyModel_Notes,",
				"          TidyAPC,",
				"          TidyCurrency,",
				"          TidyYear,",
				"          TidyDAO,",
				"          TidyLicenseType,",
				"          TidyPublisherID,",
				"          TidyJoiningID,",
				"          TidyImprint,",
				"          TidySociety,",
				"          TidyTJ,",
				"          TidyAudit,",
				"          TidyImport1_Old_Table,",
				"          TidyImport1_Old_wUID,",
				"          TidyImport1_Old_Year,",
				"          TidyPresent_via,",
				"          TidyImport2_Old_Table,",
				"          TidyImport2_Old_wUID,",
				"          TidyImport2_Old_Year,",
				"          TidyISSN_X,",
				"          TidyISSNs_in_order,",
				"          TidyIY,",
				"          TidyIYP,",
				"          TidyPublication_Data_Year,",
				"          TidyMetrics_Data_Year,",
				"          TidyCurrency_Data_Year,",
				"          TidyInflation_Data_Year,",
				"          Tidylast_year_APC,",
				"          Tidyyears_zero_APC,",
				"          Tidylast_year_model,",
				"          Tidynext_year_model",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectTidyColumns",
				"sourceAPCTitles select(mapColumn(",
				"          TitlesAPC_ID = APC_ID,",
				"          TitlesISSN_L = ISSN_L,",
				"          TitlesTitle_ID = Title_ID,",
				"          TitlesSource_title = Source_title,",
				"          TitlesTitle = Title,",
				"          TitlesPublisher = Publisher,",
				"          TitlesPublisher_Short = Publisher_Short,",
				"          TitlesPublisher_Short_OA = Publisher_Short_OA,",
				"          TitlesYear = Year,",
				"          TitlesModel = Model,",
				"          TitlesAPC = APC,",
				"          TitlesSource_title_history = Source_title_history,",
				"          TitlesTitle_history = Title_history,",
				"          TitlesPublisher_history = Publisher_history,",
				"          TitlesPublisher_history_OA = Publisher_history_OA,",
				"          TitlesYear_history = Year_history,",
				"          TitlesID_history = ID_history,",
				"          TitleswUID = wUID,",
				"          TitlesContiguous = Contiguous,",
				"          TitlesUpdates = Updates,",
				"          TitlesChild_records = Child_records,",
				"          TitlesChange_publisher = Change_publisher",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"sourceAPCTidy select(mapColumn(",
				"          TidyAPC_ID = APC_ID,",
				"          TidyTitle_ID = Title_ID,",
				"          TidyISSN_L = ISSN_L,",
				"          TidyPublisher_Short = Publisher_Short,",
				"          TidyPublisher_Short_OA = Publisher_Short_OA,",
				"          TidyPublisher_OA_type = Publisher_OA_type,",
				"          TidyUnique_title = Unique_title,",
				"          TidywUID = wUID,",
				"          TidyImport1ID = Import1ID,",
				"          TidyImport2ID = Import2ID,",
				"          TidyPublisher = Publisher,",
				"          TidyISSN1 = ISSN1,",
				"          TidyISSN2 = ISSN2,",
				"          TidyTitle = Title,",
				"          TidySource_title = Source_title,",
				"          TidySource = Source,",
				"          TidyModel = Model,",
				"          TidyModel_Notes = Model_Notes,",
				"          TidyAPC = APC,",
				"          TidyCurrency = Currency,",
				"          TidyYear = Year,",
				"          TidyDAO = DAO,",
				"          TidyLicenseType = LicenseType,",
				"          TidyPublisherID = PublisherID,",
				"          TidyJoiningID = JoiningID,",
				"          TidyImprint = Imprint,",
				"          TidySociety = Society,",
				"          TidyTJ = TJ,",
				"          TidyAudit = Audit,",
				"          TidyImport1_Old_Table = Import1_Old_Table,",
				"          TidyImport1_Old_wUID = Import1_Old_wUID,",
				"          TidyImport1_Old_Year = Import1_Old_Year,",
				"          TidyPresent_via = Present_via,",
				"          TidyImport2_Old_Table = Import2_Old_Table,",
				"          TidyImport2_Old_wUID = Import2_Old_wUID,",
				"          TidyImport2_Old_Year = Import2_Old_Year,",
				"          TidyISSN_X = ISSN_X,",
				"          TidyISSNs_in_order = ISSNs_in_order,",
				"          TidyIY = IY,",
				"          TidyIYP = IYP,",
				"          TidyPublication_Data_Year = Publication_Data_Year,",
				"          TidyMetrics_Data_Year = Metrics_Data_Year,",
				"          TidyCurrency_Data_Year = Currency_Data_Year,",
				"          TidyInflation_Data_Year = Inflation_Data_Year,",
				"          Tidylast_year_APC = last_year_APC,",
				"          Tidyyears_zero_APC = years_zero_APC,",
				"          Tidylast_year_model = last_year_model,",
				"          Tidynext_year_model = next_year_model",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"derivedColumn2 select(mapColumn(",
				"          APC_ID,",
				"          ISSN_L = sourceAPCTitles@ISSN_L,",
				"          Title_ID,",
				"          Source_title,",
				"          Title,",
				"          Publisher,",
				"          Publisher_Short,",
				"          Publisher_Short_OA,",
				"          Year = sourceAPCTitles@Year,",
				"          Model,",
				"          APC,",
				"          Source_title_history,",
				"          Title_history,",
				"          Publisher_history,",
				"          Publisher_history_OA,",
				"          Year_history,",
				"          ID_history,",
				"          wUID,",
				"          Contiguous,",
				"          Updates,",
				"          Child_records,",
				"          Change_publisher",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select9",
				"selectTidyColumns select(mapColumn(",
				"          APC_ID = TidyAPC_ID,",
				"          Title_ID = TidyTitle_ID,",
				"          ISSN_L = TidyISSN_L,",
				"          Publisher_Short = TidyPublisher_Short,",
				"          Publisher_Short_OA = TidyPublisher_Short_OA,",
				"          Publisher_OA_type = TidyPublisher_OA_type,",
				"          Unique_title = TidyUnique_title,",
				"          wUID = TidywUID,",
				"          Import1ID = TidyImport1ID,",
				"          Import2ID = TidyImport2ID,",
				"          Publisher = TidyPublisher,",
				"          ISSN1 = TidyISSN1,",
				"          ISSN2 = TidyISSN2,",
				"          Title = TidyTitle,",
				"          Source_title = TidySource_title,",
				"          Source = TidySource,",
				"          Model = TidyModel,",
				"          Model_Notes = TidyModel_Notes,",
				"          APC = TidyAPC,",
				"          Currency = TidyCurrency,",
				"          Year = TidyYear,",
				"          DAO = TidyDAO,",
				"          LicenseType = TidyLicenseType,",
				"          PublisherID = TidyPublisherID,",
				"          JoiningID = TidyJoiningID,",
				"          Imprint = TidyImprint,",
				"          Society = TidySociety,",
				"          TJ = TidyTJ,",
				"          Audit = TidyAudit,",
				"          Import1_Old_Table = TidyImport1_Old_Table,",
				"          Import1_Old_wUID = TidyImport1_Old_wUID,",
				"          Import1_Old_Year = TidyImport1_Old_Year,",
				"          Present_via = TidyPresent_via,",
				"          Import2_Old_Table = TidyImport2_Old_Table,",
				"          Import2_Old_wUID = TidyImport2_Old_wUID,",
				"          Import2_Old_Year = TidyImport2_Old_Year,",
				"          ISSN_X = TidyISSN_X,",
				"          ISSNs_in_order = TidyISSNs_in_order,",
				"          IY = TidyIY,",
				"          IYP = TidyIYP,",
				"          Publication_Data_Year = TidyPublication_Data_Year,",
				"          Metrics_Data_Year = TidyMetrics_Data_Year,",
				"          Currency_Data_Year = TidyCurrency_Data_Year,",
				"          Inflation_Data_Year = TidyInflation_Data_Year,",
				"          last_year_APC = Tidylast_year_APC,",
				"          years_zero_APC = Tidyyears_zero_APC,",
				"          last_year_model = Tidylast_year_model,",
				"          next_year_model = Tidynext_year_model",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectToSinkTidy",
				"select9 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          APC_ID as string,",
				"          ISSN_L as string,",
				"          Title_ID as string,",
				"          Source_title as string,",
				"          Title as string,",
				"          Publisher as string,",
				"          Publisher_Short as string,",
				"          Publisher_Short_OA as string,",
				"          Year as string,",
				"          Model as string,",
				"          APC as string,",
				"          Source_title_history as string,",
				"          Title_history as string,",
				"          Publisher_history as string,",
				"          Publisher_history_OA as string,",
				"          Year_history as string,",
				"          ID_history as string,",
				"          wUID as string,",
				"          Contiguous as string,",
				"          Updates as string,",
				"          Child_records as string,",
				"          Change_publisher as string",
				"     ),",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkAPCTitles",
				"selectToSinkTidy sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkAPCTidy"
			]
		}
	}
}