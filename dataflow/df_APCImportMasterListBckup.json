{
	"name": "df_APCImportMasterListBckup",
	"properties": {
		"folder": {
			"name": "apc/silver to gold/APCMasterList"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_APCMaster_APCTitles",
						"type": "DatasetReference"
					},
					"name": "sourceAPCTitles"
				},
				{
					"dataset": {
						"referenceName": "ds_APCImport_Tidy",
						"type": "DatasetReference"
					},
					"name": "sourceAPCTidy"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_APCImport_Tidy",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "filter1"
				},
				{
					"name": "APCMostRecents"
				},
				{
					"name": "JoinMostRecentMetadata"
				},
				{
					"name": "CheckExistingTitles"
				},
				{
					"name": "SplitNewAndExisting"
				},
				{
					"name": "NewRecordsProcessing"
				},
				{
					"name": "UpdateExistingRecords"
				},
				{
					"name": "select1"
				},
				{
					"name": "select2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          APC_ID as short,",
				"          ISSN_L as string,",
				"          Title_ID as integer,",
				"          Source_title as string,",
				"          Title as string,",
				"          Publisher as string,",
				"          Publisher_Short as string,",
				"          Publisher_Short_OA as string,",
				"          Year as short,",
				"          Model as string,",
				"          APC as string,",
				"          Source_title_history as string,",
				"          Title_history as string,",
				"          Publisher_history as string,",
				"          Publisher_history_OA as string,",
				"          Year_history as string,",
				"          ID_history as string,",
				"          wUID as integer,",
				"          Contiguous as boolean,",
				"          Updates as short,",
				"          Child_records as short,",
				"          Change_publisher as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceAPCTitles",
				"source(output(",
				"          APC_ID as short,",
				"          Title_ID as string,",
				"          ISSN_L as string,",
				"          Publisher_Short as string,",
				"          Publisher_Short_OA as string,",
				"          Publisher_OA_type as string,",
				"          Unique_title as string,",
				"          wUID as short,",
				"          Import1ID as string,",
				"          Import2ID as string,",
				"          Publisher as string,",
				"          ISSN1 as string,",
				"          ISSN2 as string,",
				"          Title as string,",
				"          Source_title as string,",
				"          Source as string,",
				"          Model as string,",
				"          Model_Notes as string,",
				"          APC as string,",
				"          Currency as string,",
				"          Year as short,",
				"          DAO as short,",
				"          LicenseType as string,",
				"          PublisherID as string,",
				"          JoiningID as string,",
				"          Imprint as string,",
				"          Society as string,",
				"          TJ as string,",
				"          Audit as string,",
				"          Import1_Old_Table as string,",
				"          Import1_Old_wUID as string,",
				"          Import1_Old_Year as string,",
				"          Present_via as string,",
				"          Import2_Old_Table as string,",
				"          Import2_Old_wUID as string,",
				"          Import2_Old_Year as string,",
				"          ISSN_X as string,",
				"          ISSNs_in_order as string,",
				"          IY as string,",
				"          IYP as string,",
				"          Publication_Data_Year as short,",
				"          Metrics_Data_Year as short,",
				"          Currency_Data_Year as short,",
				"          Inflation_Data_Year as short,",
				"          last_year_APC as string,",
				"          years_zero_APC as boolean,",
				"          last_year_model as string,",
				"          next_year_model as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceAPCTidy",
				"sourceAPCTidy filter(not(isNull(ISSN_L))) ~> filter1",
				"filter1 aggregate(groupBy(ISSN_L),",
				"     Year = max(Year)) ~> APCMostRecents",
				"APCMostRecents, sourceAPCTidy join(APCMostRecents@ISSN_L == sourceAPCTidy@ISSN_L",
				"     && APCMostRecents@Year == sourceAPCTidy@Year,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> JoinMostRecentMetadata",
				"select2, sourceAPCTitles lookup(TidyISSN_L == ISSN_L,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> CheckExistingTitles",
				"select1 split(isNull(ISSN_L),",
				"     disjoint: false) ~> SplitNewAndExisting@(NewRecords, ExistingRecords)",
				"SplitNewAndExisting@NewRecords derive(Updates = 0) ~> NewRecordsProcessing",
				"SplitNewAndExisting@ExistingRecords derive(Updates = Updates + 1) ~> UpdateExistingRecords",
				"CheckExistingTitles select(mapColumn(",
				"          RecentISSN_L,",
				"          RecentYear,",
				"          APC_ID = select2@APC_ID,",
				"          Title_ID = select2@Title_ID,",
				"          TidyISSN_L,",
				"          Publisher_Short = select2@Publisher_Short,",
				"          Publisher_Short_OA = select2@Publisher_Short_OA,",
				"          Publisher_OA_type,",
				"          Unique_title,",
				"          wUID = select2@wUID,",
				"          Import1ID,",
				"          Import2ID,",
				"          Publisher = select2@Publisher,",
				"          ISSN1,",
				"          ISSN2,",
				"          Title = select2@Title,",
				"          Source_title = select2@Source_title,",
				"          Source,",
				"          Model = select2@Model,",
				"          Model_Notes,",
				"          APC = select2@APC,",
				"          Currency,",
				"          TidyYear,",
				"          DAO,",
				"          LicenseType,",
				"          PublisherID,",
				"          JoiningID,",
				"          Imprint,",
				"          Society,",
				"          TJ,",
				"          Audit,",
				"          Import1_Old_Table,",
				"          Import1_Old_wUID,",
				"          Import1_Old_Year,",
				"          Present_via,",
				"          Import2_Old_Table,",
				"          Import2_Old_wUID,",
				"          Import2_Old_Year,",
				"          ISSN_X,",
				"          ISSNs_in_order,",
				"          IY,",
				"          IYP,",
				"          Publication_Data_Year,",
				"          Metrics_Data_Year,",
				"          Currency_Data_Year,",
				"          Inflation_Data_Year,",
				"          last_year_APC,",
				"          years_zero_APC,",
				"          last_year_model,",
				"          next_year_model,",
				"          APC_ID = sourceAPCTitles@APC_ID,",
				"          ISSN_L,",
				"          Title_ID = sourceAPCTitles@Title_ID,",
				"          Source_title = sourceAPCTitles@Source_title,",
				"          Title = sourceAPCTitles@Title,",
				"          Publisher = sourceAPCTitles@Publisher,",
				"          Publisher_Short = sourceAPCTitles@Publisher_Short,",
				"          Publisher_Short_OA = sourceAPCTitles@Publisher_Short_OA,",
				"          Year,",
				"          Model = sourceAPCTitles@Model,",
				"          APC = sourceAPCTitles@APC,",
				"          Source_title_history,",
				"          Title_history,",
				"          Publisher_history,",
				"          Publisher_history_OA,",
				"          Year_history,",
				"          ID_history,",
				"          wUID = sourceAPCTitles@wUID,",
				"          Contiguous,",
				"          Updates,",
				"          Child_records,",
				"          Change_publisher",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"JoinMostRecentMetadata select(mapColumn(",
				"          RecentISSN_L = APCMostRecents@ISSN_L,",
				"          RecentYear = APCMostRecents@Year,",
				"          APC_ID,",
				"          Title_ID,",
				"          TidyISSN_L = sourceAPCTidy@ISSN_L,",
				"          Publisher_Short,",
				"          Publisher_Short_OA,",
				"          Publisher_OA_type,",
				"          Unique_title,",
				"          wUID,",
				"          Import1ID,",
				"          Import2ID,",
				"          Publisher,",
				"          ISSN1,",
				"          ISSN2,",
				"          Title,",
				"          Source_title,",
				"          Source,",
				"          Model,",
				"          Model_Notes,",
				"          APC,",
				"          Currency,",
				"          TidyYear = sourceAPCTidy@Year,",
				"          DAO,",
				"          LicenseType,",
				"          PublisherID,",
				"          JoiningID,",
				"          Imprint,",
				"          Society,",
				"          TJ,",
				"          Audit,",
				"          Import1_Old_Table,",
				"          Import1_Old_wUID,",
				"          Import1_Old_Year,",
				"          Present_via,",
				"          Import2_Old_Table,",
				"          Import2_Old_wUID,",
				"          Import2_Old_Year,",
				"          ISSN_X,",
				"          ISSNs_in_order,",
				"          IY,",
				"          IYP,",
				"          Publication_Data_Year,",
				"          Metrics_Data_Year,",
				"          Currency_Data_Year,",
				"          Inflation_Data_Year,",
				"          last_year_APC,",
				"          years_zero_APC,",
				"          last_year_model,",
				"          next_year_model",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"NewRecordsProcessing sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}