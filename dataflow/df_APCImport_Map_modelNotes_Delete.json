{
	"name": "df_APCImport_Map_modelNotes_Delete",
	"properties": {
		"folder": {
			"name": "apc/silver to gold/APCImportMap"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_APCImport_Tidy",
						"type": "DatasetReference"
					},
					"name": "sourceImportTidy"
				},
				{
					"dataset": {
						"referenceName": "ds_gold_apcimport1",
						"type": "DatasetReference"
					},
					"name": "sourceAPCImport1"
				},
				{
					"dataset": {
						"referenceName": "ds_gold_apcimport2",
						"type": "DatasetReference"
					},
					"name": "sourceAPCImport2"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_APCImport_Tidy",
						"type": "DatasetReference"
					},
					"name": "UpdateAPCTidy"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "filter3"
				},
				{
					"name": "filter4"
				},
				{
					"name": "selectwUIDImport1"
				},
				{
					"name": "selectwUIDImport2"
				},
				{
					"name": "lookup2"
				},
				{
					"name": "lookup3"
				},
				{
					"name": "selectAPCTidyColumns"
				}
			],
			"scriptLines": [
				"source(output(",
				"          APC_ID as long,",
				"          Title_ID as string,",
				"          ISSN_L as string,",
				"          Publisher_Short as string,",
				"          Publisher_Short_OA as string,",
				"          Publisher_OA_type as string,",
				"          Unique_title as string,",
				"          wUID as long,",
				"          Import1ID as string,",
				"          Import2ID as string,",
				"          Publisher as string,",
				"          ISSN1 as string,",
				"          ISSN2 as string,",
				"          Title as string,",
				"          Source_title as string,",
				"          Source as string,",
				"          Model as string,",
				"          Model_Notes as string,",
				"          APC as string,",
				"          Currency as string,",
				"          Year as short,",
				"          DAO as short,",
				"          LicenseType as string,",
				"          PublisherID as string,",
				"          JoiningID as string,",
				"          Imprint as string,",
				"          Society as string,",
				"          TJ as string,",
				"          Audit as string,",
				"          Import1_Old_Table as string,",
				"          Import1_Old_wUID as string,",
				"          Import1_Old_Year as string,",
				"          Present_via as string,",
				"          Import2_Old_Table as string,",
				"          Import2_Old_wUID as string,",
				"          Import2_Old_Year as string,",
				"          ISSN_X as string,",
				"          ISSNs_in_order as string,",
				"          IY as string,",
				"          IYP as string,",
				"          Publication_Data_Year as short,",
				"          Metrics_Data_Year as short,",
				"          Currency_Data_Year as short,",
				"          Inflation_Data_Year as short,",
				"          last_year_APC as string,",
				"          years_zero_APC as boolean,",
				"          last_year_model as string,",
				"          next_year_model as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceImportTidy",
				"source(output(",
				"          wUID as short,",
				"          Publisher as string,",
				"          ISSN1 as string,",
				"          ISSN2 as string,",
				"          Title as string,",
				"          Source as string,",
				"          Model as string,",
				"          {Model Notes} as string,",
				"          APC as string,",
				"          Currency as string,",
				"          Year as short,",
				"          DAO as short,",
				"          LicenseType as string,",
				"          PublisherID as short,",
				"          JoiningID as short,",
				"          Imprint as string,",
				"          Society as string,",
				"          TJ as string,",
				"          Audit as timestamp,",
				"          Old_Table as string,",
				"          Old_wUID as short,",
				"          Old_Year as short",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceAPCImport1",
				"source(output(",
				"          wUID as short,",
				"          Publisher as string,",
				"          ISSN1 as string,",
				"          ISSN2 as string,",
				"          Title as string,",
				"          Source as string,",
				"          Model as string,",
				"          {Model Notes} as string,",
				"          APC as short,",
				"          Currency as string,",
				"          Year as short,",
				"          DAO as short,",
				"          LicenseType as string,",
				"          PublisherID as string,",
				"          JoiningID as string,",
				"          Imprint as string,",
				"          Society as string,",
				"          TJ as string,",
				"          Audit as timestamp,",
				"          Old_Table as string,",
				"          Old_wUID as short,",
				"          Old_Year as short",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceAPCImport2",
				"lookup3 derive(Model_Notes = iif(\r",
				"    not(isNull(Model_Notes)) && not(startsWith(Model_Notes, 'DELETE') && \r",
				"    ((Import1ID == toString(selectwUIDImport1@wUID)) || Import2ID == toString(selectwUIDImport2@wUID))),\r",
				"    \"DELETE - as marked\",\r",
				"    Model_Notes),",
				"          ISSN_L = toString(null())) ~> derivedColumn1",
				"sourceAPCImport1 filter(startsWith({Model Notes}, 'DELETE')) ~> filter3",
				"sourceAPCImport2 filter(startsWith({Model Notes}, 'DELETE')) ~> filter4",
				"filter3 select(mapColumn(",
				"          wUID",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectwUIDImport1",
				"filter4 select(mapColumn(",
				"          wUID",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectwUIDImport2",
				"sourceImportTidy, selectwUIDImport1 lookup(Import1ID == toString(selectwUIDImport1@wUID),",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup2",
				"lookup2, selectwUIDImport2 lookup(Import2ID == toString(selectwUIDImport2@wUID),",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup3",
				"derivedColumn1 select(mapColumn(",
				"          APC_ID,",
				"          Title_ID,",
				"          ISSN_L,",
				"          Publisher_Short,",
				"          Publisher_Short_OA,",
				"          Publisher_OA_type,",
				"          Unique_title,",
				"          wUID = sourceImportTidy@wUID,",
				"          Import1ID,",
				"          Import2ID,",
				"          Publisher,",
				"          ISSN1,",
				"          ISSN2,",
				"          Title,",
				"          Source_title,",
				"          Source,",
				"          Model,",
				"          Model_Notes,",
				"          APC,",
				"          Currency,",
				"          Year,",
				"          DAO,",
				"          LicenseType,",
				"          PublisherID,",
				"          JoiningID,",
				"          Imprint,",
				"          Society,",
				"          TJ,",
				"          Audit,",
				"          Import1_Old_Table,",
				"          Import1_Old_wUID,",
				"          Import1_Old_Year,",
				"          Present_via,",
				"          Import2_Old_Table,",
				"          Import2_Old_wUID,",
				"          Import2_Old_Year,",
				"          ISSN_X,",
				"          ISSNs_in_order,",
				"          IY,",
				"          IYP,",
				"          Publication_Data_Year,",
				"          Metrics_Data_Year,",
				"          Currency_Data_Year,",
				"          Inflation_Data_Year,",
				"          last_year_APC,",
				"          years_zero_APC,",
				"          last_year_model,",
				"          next_year_model",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectAPCTidyColumns",
				"selectAPCTidyColumns sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['APCTidy.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> UpdateAPCTidy"
			]
		}
	}
}