{
	"name": "df_APCImportMapMissingIssnL_wUID",
	"properties": {
		"folder": {
			"name": "apc/silver to gold/APCImportMap"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_gold_APC_tidy_ISSN_Ls",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_gold_APC_tidy_ISSN_Ls",
						"type": "DatasetReference"
					},
					"name": "sinkAPCTidyISSNLs"
				}
			],
			"transformations": [
				{
					"name": "filter1"
				},
				{
					"name": "selectwUID"
				},
				{
					"name": "lookup1"
				},
				{
					"name": "derivedMissingTable"
				},
				{
					"name": "filter2"
				},
				{
					"name": "APCTidyISSNLs"
				},
				{
					"name": "lookup2"
				},
				{
					"name": "derivedViawUID"
				},
				{
					"name": "selectMissingTable"
				}
			],
			"scriptLines": [
				"source(output(",
				"          wUID as long,",
				"          ISSN as string,",
				"          ISSN_L as string,",
				"          Title as string,",
				"          Source_title as string,",
				"          Publisher as string,",
				"          PublisherID as string,",
				"          ISSN_L_via as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 filter(isNull(ISSN_L)) ~> filter1",
				"filter1 select(mapColumn(",
				"          wUID",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectwUID",
				"source1, selectwUID lookup(source1@wUID == selectwUID@wUID,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"lookup1 derive(wUID = source1@wUID,",
				"          ISSN_L = iif(not(isNull(ISSN_L)),ISSN_L,toString(null()))) ~> derivedMissingTable",
				"derivedMissingTable filter(not(isNull(ISSN_L))) ~> filter2",
				"source1 select(mapColumn(",
				"          wUID,",
				"          ISSN,",
				"          ISSN_L,",
				"          Title,",
				"          Source_title,",
				"          Publisher,",
				"          PublisherID,",
				"          ISSN_L_via",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> APCTidyISSNLs",
				"APCTidyISSNLs, selectMissingTable lookup(APCTidyISSNLs@wUID == selectMissingTable@wUID,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup2",
				"lookup2 derive(ISSN_L = :missing_ISSN_L_V,",
				"          ISSN_L_via = iif(not(isNull(:missing_ISSN_L_V)) && isNull(:APCTidyIssnl_V),'wUID',APCTidyISSNLs@ISSN_L_via),",
				"          missing_ISSN_L_V := iif(isNull(APCTidyISSNLs@ISSN_L),selectMissingTable@ISSN_L,APCTidyISSNLs@ISSN_L),",
				"          APCTidyIssnl_V := APCTidyISSNLs@ISSN_L) ~> derivedViawUID",
				"filter2 select(mapColumn(",
				"          wUID,",
				"          ISSN,",
				"          ISSN_L,",
				"          Title,",
				"          Source_title,",
				"          Publisher,",
				"          PublisherID,",
				"          ISSN_L_via",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectMissingTable",
				"derivedViawUID sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          wUID as string,",
				"          ISSN1 as string,",
				"          ISSN2 as string,",
				"          Title as string,",
				"          Source as string,",
				"          Model as string,",
				"          {Model Notes} as string,",
				"          APC as string,",
				"          Currency as string,",
				"          Year as string,",
				"          LicenseType as string,",
				"          PublisherID as string,",
				"          JoiningID as string,",
				"          Imprint as string,",
				"          Society as string,",
				"          TJ as string,",
				"          Audit as string,",
				"          Old_Table as string,",
				"          Old_wUID as string,",
				"          Old_Year as string,",
				"          DAO as string,",
				"          Publisher as string",
				"     ),",
				"     partitionFileNames:['MissingIssnl.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sinkAPCTidyISSNLs"
			]
		}
	}
}