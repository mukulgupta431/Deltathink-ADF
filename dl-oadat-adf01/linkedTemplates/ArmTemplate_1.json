						"input(output(",
						"          APC_ID as short,",
						"          Title_ID as string,",
						"          ISSN_L as string,",
						"          Publisher_Short as string,",
						"          Publisher_Short_OA as string,",
						"          Publisher_OA_type as string,",
						"          Unique_title as string,",
						"          wUID as short,",
						"          Import1ID as string,",
						"          Import2ID as string,",
						"          Publisher as string,",
						"          ISSN1 as string,",
						"          ISSN2 as string,",
						"          Title as string,",
						"          Source_title as string,",
						"          Source as string,",
						"          Model as string,",
						"          Model_Notes as string,",
						"          APC as string,",
						"          Currency as string,",
						"          Year as short,",
						"          DAO as short,",
						"          LicenseType as string,",
						"          PublisherID as string,",
						"          JoiningID as string,",
						"          Imprint as string,",
						"          Society as string,",
						"          TJ as string,",
						"          Audit as string,",
						"          Import1_Old_Table as string,",
						"          Import1_Old_wUID as string,",
						"          Import1_Old_Year as string,",
						"          Present_via as string,",
						"          Import2_Old_Table as string,",
						"          Import2_Old_wUID as string,",
						"          Import2_Old_Year as string,",
						"          ISSN_X as string,",
						"          ISSNs_in_order as string,",
						"          IY as string,",
						"          IYP as string,",
						"          Publication_Data_Year as short,",
						"          Metrics_Data_Year as short,",
						"          Currency_Data_Year as short,",
						"          Inflation_Data_Year as short,",
						"          last_year_APC as string,",
						"          years_zero_APC as boolean,",
						"          last_year_model as string,",
						"          next_year_model as string,",
						"          {source2@ISSN_L} as string",
						"     ),",
						"     order: 0,",
						"     allowSchemaDrift: true) ~> input1",
						"input(output(",
						"          ISSN as string,",
						"          ISSN_L as string",
						"     ),",
						"     order: 1,",
						"     allowSchemaDrift: true) ~> input2",
						"derivedColumn1 select(mapColumn(",
						"          wUID,",
						"          ISSN = ISSN1,",
						"          ISSN_L = {source2@ISSN_L},",
						"          Title,",
						"          Source_title,",
						"          Publisher,",
						"          PublisherID,",
						"          ISSN_L_via",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> select1",
						"select1, input1 union(byName: true)~> union1",
						"union1 select(mapColumn(",
						"          wUID,",
						"          ISSN,",
						"          ISSN_L,",
						"          Title,",
						"          Source_title,",
						"          Publisher,",
						"          PublisherID,",
						"          ISSN_L_via",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> APCTidyISSNLs",
						"derivedMissingTable filter(not(isNull(ISSN_L))) ~> filter3",
						"lookup3 derive(wUID = union1@wUID,",
						"          ISSN_L = iif(not(isNull(ISSN_L)),ISSN_L,toString(null()))) ~> derivedMissingTable",
						"union1 filter(isNull(ISSN_L)) ~> filter4",
						"filter4 select(mapColumn(",
						"          wUID",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> selectwUID",
						"union1, selectwUID lookup(union1@wUID == selectwUID@wUID,",
						"     multiple: false,",
						"     pickup: 'any',",
						"     broadcast: 'auto')~> lookup3",
						"APCTidyISSNLs, derivedMissingTable lookup(APCTidyISSNLs@wUID == derivedMissingTable@wUID,",
						"     multiple: false,",
						"     pickup: 'any',",
						"     broadcast: 'auto')~> lookup4",
						"lookup4 derive(ISSN_L = :missing_ISSN_L_v,",
						"          ISSN_L_via = iif(not(isNull(:missing_ISSN_L_v)),'wUID',toString(null())),",
						"          missing_ISSN_L_v := iif(isNull(APCTidyISSNLs@ISSN_L),derivedMissingTable@ISSN_L,APCTidyISSNLs@ISSN_L)) ~> derivedViawUID",
						"input1 derive(ISSN_L_via = toString(null())) ~> derivedColumn1",
						"derivedViawUID select(mapColumn(",
						"          wUID = APCTidyISSNLs@wUID,",
						"          ISSN = APCTidyISSNLs@ISSN,",
						"          ISSN_L,",
						"          Title = APCTidyISSNLs@Title,",
						"          Source_title = APCTidyISSNLs@Source_title,",
						"          Publisher = APCTidyISSNLs@Publisher,",
						"          PublisherID = APCTidyISSNLs@PublisherID,",
						"          ISSN_L_via,",
						"          wUID = derivedMissingTable@wUID,",
						"          ISSN = union1@ISSN,",
						"          Title = union1@Title,",
						"          Source_title = union1@Source_title,",
						"          Publisher = union1@Publisher,",
						"          PublisherID = union1@PublisherID,",
						"          APC_ID,",
						"          Title_ID,",
						"          Publisher_Short,",
						"          Publisher_Short_OA,",
						"          Publisher_OA_type,",
						"          Unique_title,",
						"          Import1ID,",
						"          Import2ID,",
						"          ISSN1,",
						"          ISSN2,",
						"          Source,",
						"          Model,",
						"          Model_Notes,",
						"          APC,",
						"          Currency,",
						"          Year,",
						"          DAO,",
						"          LicenseType,",
						"          JoiningID,",
						"          Imprint,",
						"          Society,",
						"          TJ,",
						"          Audit,",
						"          Import1_Old_Table,",
						"          Import1_Old_wUID,",
						"          Import1_Old_Year,",
						"          Present_via,",
						"          Import2_Old_Table,",
						"          Import2_Old_wUID,",
						"          Import2_Old_Year,",
						"          ISSN_X,",
						"          ISSNs_in_order,",
						"          IY,",
						"          IYP,",
						"          Publication_Data_Year,",
						"          Metrics_Data_Year,",
						"          Currency_Data_Year,",
						"          Inflation_Data_Year,",
						"          last_year_APC,",
						"          years_zero_APC,",
						"          last_year_model,",
						"          next_year_model",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> select2",
						"select2 output() ~> outputAPCTidyISSNLs"
					]
				}
			},
			"dependsOn": []
		},
